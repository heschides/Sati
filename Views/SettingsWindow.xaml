<Window x:Class="Sati.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings"
        Height="620"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FDF6EC">

    <Window.Resources>
        <Style x:Key="LabelStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="Margin"
                    Value="0,0,0,5" />
        </Style>

        <Style x:Key="SectionHeader"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding"
                    Value="8,4" />
            <Setter Property="Width"
                    Value="100" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="HorizontalAlignment"
                    Value="Left" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,12" />
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background"
                    Value="#E8D0B8" />
            <Setter Property="Margin"
                    Value="0,4,0,16" />
        </Style>

        <Style x:Key="PrimaryButton"
               TargetType="Button">
            <Setter Property="Height"
                    Value="36" />
            <Setter Property="Background"
                    Value="#C87941" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#A85E28" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#8A4D20" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="32">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- BILLING -->
                <TextBlock Text="BILLING"
                           Style="{StaticResource SectionHeader}" />
                <Separator />

                <TextBlock Text="DAYS BEFORE NOTE IS ABANDONED"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding AbandonedAfterDays, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="PRODUCTIVITY THRESHOLD (UNITS/DAY)"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding ProductivityThreshold, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="BASE INCENTIVE ($)"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding BaseIncentive, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="PER-UNIT INCENTIVE ($)"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding PerUnitIncentive, UpdateSourceTrigger=PropertyChanged}" />

                <!-- NOTE TEMPLATES -->
                <TextBlock Text="NOTE TEMPLATES"
                           Style="{StaticResource SectionHeader}"
                           Margin="0,8,0,8" />
                <Separator />

                <TextBlock Text="VISIT TEMPLATE"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding VisitTemplate, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="190"
                         VerticalScrollBarVisibility="Auto"
                         Width="361" />

                <TextBlock Text="CONTACT TEMPLATE"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding ContactTemplate, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="247"
                         VerticalScrollBarVisibility="Auto"
                         Width="354" />

                <TextBlock Text="DOCUMENTATION TEMPLATE"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding DocumentationTemplate, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="294"
                         VerticalScrollBarVisibility="Auto"
                         Width="351" />

                <!-- SAVE -->
                <Button Content="Save Settings"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveSettingsCommand}"
                        Margin="0,16,0,0" />

            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>