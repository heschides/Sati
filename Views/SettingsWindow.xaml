<Window x:Class="Sati.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings"
        Height="620"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FDF6EC">

    <Window.Resources>
        <Style x:Key="LabelStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="Margin"
                    Value="0,0,0,5" />
        </Style>

        <Style x:Key="SectionHeader"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding"
                    Value="8,4" />
            <Setter Property="Width"
                    Value="100" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="HorizontalAlignment"
                    Value="Left" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,12" />
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background"
                    Value="#E8D0B8" />
            <Setter Property="Margin"
                    Value="0,4,0,16" />
        </Style>

        <Style x:Key="PrimaryButton"
               TargetType="Button">
            <Setter Property="Height"
                    Value="36" />
            <Setter Property="Background"
                    Value="#C87941" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#A85E28" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#8A4D20" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="32">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- BILLING -->
                <TextBlock Text="BILLING"
                           Style="{StaticResource SectionHeader}" />
                <Separator />

                <TextBlock Text="DAYS BEFORE NOTE IS ABANDONED"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding AbandonedAfterDays, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="PRODUCTIVITY THRESHOLD (UNITS/DAY)"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding ProductivityThreshold, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="BASE INCENTIVE ($)"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding BaseIncentive, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="PER-UNIT INCENTIVE ($)"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding PerUnitIncentive, UpdateSourceTrigger=PropertyChanged}" />

                <!-- SCHEDULE EXCLUSIONS -->
                <TextBlock Text="EXCLUDED WEEKDAYS"
                           Style="{StaticResource SectionHeader}"
                           Margin="0,8,0,8" />
                <Separator />

                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,12">
                    <CheckBox Content="Monday"
                              IsChecked="{Binding ExcludeMonday}"
                              Margin="0,0,16,0"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Tuesday"
                              IsChecked="{Binding ExcludeTuesday}"
                              Margin="0,0,16,0"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Wednesday"
                              IsChecked="{Binding ExcludeWednesday}"
                              Margin="0,0,16,0"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Thursday"
                              IsChecked="{Binding ExcludeThursday}"
                              Margin="0,0,16,0"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Friday"
                              IsChecked="{Binding ExcludeFriday}"
                              Foreground="#3D2B1F" />
                </StackPanel>

                <!-- FEDERAL HOLIDAYS -->
                <TextBlock Text="FEDERAL HOLIDAYS"
                           Style="{StaticResource SectionHeader}"
                           Margin="0,8,0,8" />
                <Separator />

                <WrapPanel Margin="0,0,0,12">
                    <CheckBox Content="New Year's Day"
                              IsChecked="{Binding ExcludeNewYearsDay}"
                              Margin="0,0,16,8"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="MLK Day"
                              IsChecked="{Binding ExcludeMLKDay}"
                              Margin="0,0,16,8"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Presidents Day"
                              IsChecked="{Binding ExcludePresidentsDay}"
                              Margin="0,0,16,8"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Memorial Day"
                              IsChecked="{Binding ExcludeMemorialDay}"
                              Margin="0,0,16,8"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Juneteenth"
                              IsChecked="{Binding ExcludeJuneteenth}"
                              Margin="0,0,16,8"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Independence Day"
                              IsChecked="{Binding ExcludeIndependenceDay}"
                              Margin="0,0,16,8"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Labor Day"
                              IsChecked="{Binding ExcludeLaborDay}"
                              Margin="0,0,16,8"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Indigenous Peoples Day"
                              IsChecked="{Binding ExcludeIndigenousPeoplesDay}"
                              Margin="0,0,16,8"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Veterans Day"
                              IsChecked="{Binding ExcludeVeteransDay}"
                              Margin="0,0,16,8"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Thanksgiving"
                              IsChecked="{Binding ExcludeThanksgiving}"
                              Margin="0,0,16,8"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Day After Thanksgiving"
                              IsChecked="{Binding ExcludeDayAfterThanksgiving}"
                              Margin="0,0,16,8"
                              Foreground="#3D2B1F" />
                    <CheckBox Content="Christmas"
                              IsChecked="{Binding ExcludeChristmas}"
                              Margin="0,0,16,8"
                              Foreground="#3D2B1F" />
                </WrapPanel>

                <!-- NOTE TEMPLATES -->
                <TextBlock Text="NOTE TEMPLATES"
                           Style="{StaticResource SectionHeader}"
                           Margin="0,8,0,8" />
                <Separator />

                <TextBlock Text="VISIT TEMPLATE"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding VisitTemplate, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="190"
                         VerticalScrollBarVisibility="Auto"
                         Width="361" />

                <TextBlock Text="CONTACT TEMPLATE"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding ContactTemplate, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="247"
                         VerticalScrollBarVisibility="Auto"
                         Width="354" />

                <TextBlock Text="DOCUMENTATION TEMPLATE"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding DocumentationTemplate, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="294"
                         VerticalScrollBarVisibility="Auto"
                         Width="351" />
                
                <!-- Form Deadline Windows -->
<TextBlock Text="FORM DEADLINE WINDOWS"
           Style="{StaticResource SectionHeader}"
           Margin="0,16,0,8"/>

<Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="180"/>
        <ColumnDefinition Width="120"/>
        <ColumnDefinition Width="120"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />

                    </Grid.RowDefinitions>

    <!-- Column headers -->
    <TextBlock Grid.Row="0" Grid.Column="1"
               Text="Open Days Before"
               Style="{StaticResource LabelStyle}"
               HorizontalAlignment="Center"/>
    <TextBlock Grid.Row="0" Grid.Column="2"
               Text="Days After Due"
               Style="{StaticResource LabelStyle}"
               HorizontalAlignment="Center"/>

    <!-- Reviews -->
    <TextBlock Grid.Row="1" Grid.Column="0"
               Text="Reviews"
               Style="{StaticResource LabelStyle}"
               VerticalAlignment="Center"/>
    <TextBox Grid.Row="1" Grid.Column="1"
             Text="{Binding ReviewOpenDaysBefore, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,4,8"/>
    <TextBox Grid.Row="1" Grid.Column="2"
             Text="{Binding ReviewDaysAfterDue, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,0,8"/>

    <!-- PCP -->
    <TextBlock Grid.Row="2" Grid.Column="0"
               Text="PCP"
               Style="{StaticResource LabelStyle}"
               VerticalAlignment="Center"/>
    <TextBox Grid.Row="2" Grid.Column="1"
             Text="{Binding PcpOpenDaysBefore, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,4,8"/>
    <TextBox Grid.Row="2" Grid.Column="2"
             Text="{Binding PcpDaysAfterDue, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,0,8"/>

    <!-- Comprehensive Assessment -->
    <TextBlock Grid.Row="3" Grid.Column="0"
               Text="Comp. Assessment"
               Style="{StaticResource LabelStyle}"
               VerticalAlignment="Center"/>
    <TextBox Grid.Row="3" Grid.Column="1"
             Text="{Binding CompAssessmentOpenDaysBefore, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,4,8"/>
    <TextBox Grid.Row="3" Grid.Column="2"
             Text="{Binding CompAssessmentDaysAfterDue, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,0,8"/>

    <!-- Reclassification -->
    <TextBlock Grid.Row="4" Grid.Column="0"
               Text="Reclassification"
               Style="{StaticResource LabelStyle}"
               VerticalAlignment="Center"/>
    <TextBox Grid.Row="4" Grid.Column="1"
             Text="{Binding ReclassificationOpenDaysBefore, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,4,8"/>
    <TextBox Grid.Row="4" Grid.Column="2"
             Text="{Binding ReclassificationDaysAfterDue, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,0,8"/>

    <!-- Safety Plan -->
    <TextBlock Grid.Row="5" Grid.Column="0"
               Text="Safety Plan"
               Style="{StaticResource LabelStyle}"
               VerticalAlignment="Center"/>
    <TextBox Grid.Row="5" Grid.Column="1"
             Text="{Binding SafetyPlanOpenDaysBefore, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,4,8"/>
    <TextBox Grid.Row="5" Grid.Column="2"
             Text="{Binding SafetyPlanDaysAfterDue, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,0,8"/>

    <!-- Privacy Practices -->
    <TextBlock Grid.Row="6" Grid.Column="0"
               Text="Privacy Practices"
               Style="{StaticResource LabelStyle}"
               VerticalAlignment="Center"/>
    <TextBox Grid.Row="6" Grid.Column="1"
             Text="{Binding PrivacyPracticesOpenDaysBefore, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,4,8"/>
    <TextBox Grid.Row="6" Grid.Column="2"
             Text="{Binding PrivacyPracticesDaysAfterDue, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,0,8"/>

    <!-- Release Agency -->
    <TextBlock Grid.Row="7" Grid.Column="0"
               Text="Release — Agency"
               Style="{StaticResource LabelStyle}"
               VerticalAlignment="Center"/>
    <TextBox Grid.Row="7" Grid.Column="1"
             Text="{Binding ReleaseAgencyOpenDaysBefore, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,4,8"/>
    <TextBox Grid.Row="7" Grid.Column="2"
             Text="{Binding ReleaseAgencyDaysAfterDue, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,0,8"/>

    <!-- Release DHHS -->
    <TextBlock Grid.Row="8" Grid.Column="0"
               Text="Release — DHHS"
               Style="{StaticResource LabelStyle}"
               VerticalAlignment="Center"/>
    <TextBox Grid.Row="8" Grid.Column="1"
             Text="{Binding ReleaseDhhsOpenDaysBefore, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,4,8"/>
    <TextBox Grid.Row="8" Grid.Column="2"
             Text="{Binding ReleaseDhhsDaysAfterDue, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,0,8"/>

    <!-- Release Medical -->
    <TextBlock Grid.Row="9" Grid.Column="0"
               Text="Release — Medical"
               Style="{StaticResource LabelStyle}"
               VerticalAlignment="Center"/>
    <TextBox Grid.Row="9" Grid.Column="1"
             Text="{Binding ReleaseMedicalOpenDaysBefore, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,4,8"/>
    <TextBox Grid.Row="10" Grid.Column="2"
             Text="{Binding ReleaseMedicalDaysAfterDue, UpdateSourceTrigger=PropertyChanged}"
             Margin="4,0,0,8"/>
</Grid>

                <!-- SAVE -->
                <Button Content="Save Settings"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveSettingsCommand}"
                        Margin="0,16,0,0" />

            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>