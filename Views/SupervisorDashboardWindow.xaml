<UserControl x:Class="Sati.Views.SupervisorDashboardWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sati="clr-namespace:Sati"
             Background="#FDF6EC"
             TextElement.FontFamily="{StaticResource AppFont}">

    <UserControl.Resources>

        <Style x:Key="MetricCard"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#F0E4D0" />
            <Setter Property="BorderBrush"
                    Value="#E8D0B8" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="CornerRadius"
                    Value="6" />
            <Setter Property="Padding"
                    Value="12,10" />
            <Setter Property="Margin"
                    Value="0,0,10,0" />
        </Style>

        <Style x:Key="MetricLabel"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="10" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="Margin"
                    Value="0,0,0,4" />
        </Style>

        <Style x:Key="SectionHeading"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Margin"
                    Value="0,0,0,6" />
        </Style>

        <Style x:Key="SidebarHeading"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="10" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Margin"
                    Value="12,12,12,4" />
        </Style>

        <Style x:Key="QuickFilter"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="Margin"
                    Value="0,3" />
            <Setter Property="Cursor"
                    Value="Hand" />
        </Style>

        <Style x:Key="TeamProgressBar"
               TargetType="ProgressBar">
            <Setter Property="Height"
                    Value="6" />
            <Setter Property="Width"
                    Value="80" />
            <Setter Property="Background"
                    Value="#E8D0B8" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Height="6">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    CornerRadius="3"
                                    Background="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="FontSize"
                    Value="10" />
            <Setter Property="FontWeight"
                    Value="Normal" />
            <Setter Property="Padding"
                    Value="8,6" />
            <Setter Property="BorderBrush"
                    Value="#E8D0B8" />
            <Setter Property="BorderThickness"
                    Value="0,0,0,1" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="8,0"
                                Background="{TemplateBinding Background}"
                                VerticalAlignment="Stretch">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected"
                         Value="True">
                    <Setter Property="Background"
                            Value="#F5EAD8" />
                    <Setter Property="Foreground"
                            Value="#3D2B1F" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#F5EAD8" />
                </Trigger>
                <Trigger Property="IsSelected"
                         Value="True">
                    <Setter Property="Background"
                            Value="#F5EAD8" />
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ================================================================ -->
        <!-- TOOLBAR                                                           -->
        <!-- ================================================================ -->
        <Border Grid.Row="0"
                Background="#F0E4D0"
                BorderBrush="#E8D0B8"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">

                <!-- Team overview -->
                <Border Cursor="Hand"
                        CornerRadius="4"
                        Padding="12,4"
                        Margin="0,0,4,0">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding NavigateToTeamOverviewCommand}" />
                    </Border.InputBindings>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTeamOverviewActive}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="#C87941" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="Team overview"
                               FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="#9C7A5C" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTeamOverviewActive}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="#FDF6EC" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- Overdue items -->
                <Border Cursor="Hand"
                        CornerRadius="4"
                        Padding="12,4"
                        Margin="0,0,4,0">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding NavigateToOverdueItemsCommand}" />
                    </Border.InputBindings>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOverdueItemsActive}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="#C87941" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="Overdue items"
                               FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="#9C7A5C" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOverdueItemsActive}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="#FDF6EC" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- Monthly productivity -->
                <Border Cursor="Hand"
                        CornerRadius="4"
                        Padding="12,4"
                        Margin="0,0,16,0">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding NavigateToMonthlyProductivityCommand}" />
                    </Border.InputBindings>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMonthlyProductivityActive}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="#C87941" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="Monthly productivity"
                               FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="#9C7A5C" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMonthlyProductivityActive}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="#FDF6EC" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <Border Width="1"
                        Background="#E8D0B8"
                        Margin="0,2,16,2" />

                <TextBlock Text="MONTH"
                           FontSize="11"
                           Foreground="#9C7A5C"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="{Binding CurrentMonth, Mode=OneWay}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#3D2B1F"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0" />

                <Border Width="1"
                        Background="#E8D0B8"
                        Margin="0,2,16,2" />

                <TextBlock Text="TEAM SIZE"
                           FontSize="11"
                           Foreground="#9C7A5C"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="{Binding TeamSizeLabel}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#3D2B1F"
                           VerticalAlignment="Center" />

            </StackPanel>
        </Border>

        <!-- ================================================================ -->
        <!-- SUMMARY METRICS                                                   -->
        <!-- ================================================================ -->
        <UniformGrid Grid.Row="1"
                     Rows="1"
                     Columns="4"
                     Margin="16,12,16,0">

            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="TOTAL CLIENTS"
                               Style="{StaticResource MetricLabel}" />
                    <TextBlock Text="{Binding TotalClients}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#3D2B1F" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="OVERDUE ITEMS"
                               Style="{StaticResource MetricLabel}" />
                    <TextBlock Text="{Binding TotalOverdue}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#A83220" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="NOTES THIS MONTH"
                               Style="{StaticResource MetricLabel}" />
                    <TextBlock Text="{Binding TotalNotesThisMonth}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#3D2B1F" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCard}"
                    Margin="0">
                <StackPanel>
                    <TextBlock Text="AVG COMPLIANCE"
                               Style="{StaticResource MetricLabel}" />
                    <TextBlock Text="{Binding AvgComplianceLabel}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#3A6B35" />
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- ================================================================ -->
        <!-- BODY                                                              -->
        <!-- ================================================================ -->
        <Grid Grid.Row="2"
              Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ============================================================ -->
            <!-- SIDEBAR                                                       -->
            <!-- ============================================================ -->
            <Border Grid.Column="0"
                    Background="#F5EAD8"
                    BorderBrush="#E8D0B8"
                    BorderThickness="0,0,1,0">
                <StackPanel>

                    <!-- Case managers header — clickable, navigates to user management -->
                    <Border Cursor="Hand"
                            Padding="0">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding NavigateToUserManagementCommand}" />
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUserManagementActive}"
                                                 Value="True">
                                        <Setter Property="Background"
                                                Value="#EDD9C0" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#EDD9C0" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal"
                                    Margin="12,12,12,4">
                            <TextBlock Text="CASE MANAGERS"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#9C7A5C" />
                            <TextBlock Text=" ›"
                                       FontSize="10"
                                       Foreground="#C87941"
                                       Margin="4,0,0,0" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding CaseManagers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Cursor="Hand"
                                        Padding="0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="Transparent" />
                                            <Setter Property="BorderThickness"
                                                    Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="#EDD9C0" />
                                                    <Setter Property="BorderThickness"
                                                            Value="3,0,0,0" />
                                                    <Setter Property="BorderBrush"
                                                            Value="#C87941" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                    <Setter Property="Background"
                                                            Value="#EDD9C0" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="12,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="28"
                                                Height="28"
                                                CornerRadius="14"
                                                Background="#C87941"
                                                Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Initials}"
                                                       FontSize="11"
                                                       Foreground="#FDF6EC"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="12"
                                                       Foreground="#3D2B1F" />
                                            <TextBlock Text="{Binding ClientCountLabel}"
                                                       FontSize="10"
                                                       Foreground="#9C7A5C" />
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Background="#A83220"
                                                CornerRadius="10"
                                                Padding="6,1"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding HasOverdue,
                                                    Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="{Binding OverdueCount}"
                                                       FontSize="10"
                                                       Foreground="#FDF6EC" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="QUICK FILTERS"
                               Style="{StaticResource SidebarHeading}"
                               Margin="12,16,12,4" />

                    <StackPanel Margin="12,0">
                        <TextBlock Text="▶ Has overdue items"
                                   Style="{StaticResource QuickFilter}" />
                        <TextBlock Text="▶ Below threshold"
                                   Style="{StaticResource QuickFilter}" />
                        <TextBlock Text="▶ Missing this month"
                                   Style="{StaticResource QuickFilter}" />
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ============================================================ -->
            <!-- MAIN CONTENT — sub-view ContentControl                        -->
            <!-- ============================================================ -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentSubView}" />

        </Grid>
    </Grid>
</UserControl>