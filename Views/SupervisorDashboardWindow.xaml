<Window x:Class="Sati.Views.SupervisorDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sati — Supervisor Dashboard"
        Height="660"
        Width="1020"
        WindowStartupLocation="CenterScreen"
        Background="#FDF6EC"
        FontFamily="Segoe UI">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="MetricCard"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#F0E4D0" />
            <Setter Property="BorderBrush"
                    Value="#E8D0B8" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="CornerRadius"
                    Value="6" />
            <Setter Property="Padding"
                    Value="12,10" />
            <Setter Property="Margin"
                    Value="0,0,10,0" />
        </Style>

        <Style x:Key="MetricLabel"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="10" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="Margin"
                    Value="0,0,0,4" />
        </Style>

        <Style x:Key="SectionHeading"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Margin"
                    Value="0,0,0,6" />
        </Style>

        <Style x:Key="SidebarHeading"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="10" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Margin"
                    Value="12,12,12,4" />
        </Style>

        <Style x:Key="QuickFilter"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="Margin"
                    Value="0,3" />
            <Setter Property="Cursor"
                    Value="Hand" />
        </Style>

        <Style x:Key="TabButton"
               TargetType="Border">
            <Setter Property="CornerRadius"
                    Value="4" />
            <Setter Property="Padding"
                    Value="12,4" />
            <Setter Property="Margin"
                    Value="0,0,4,0" />
            <Setter Property="Cursor"
                    Value="Hand" />
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="GridLinesVisibility"
                    Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush"
                    Value="#F0E4D0" />
            <Setter Property="RowBackground"
                    Value="Transparent" />
            <Setter Property="AlternatingRowBackground"
                    Value="Transparent" />
            <Setter Property="HeadersVisibility"
                    Value="Column" />
            <Setter Property="IsReadOnly"
                    Value="True" />
            <Setter Property="SelectionMode"
                    Value="Single" />
            <Setter Property="CanUserResizeColumns"
                    Value="False" />
            <Setter Property="CanUserReorderColumns"
                    Value="False" />
            <Setter Property="AutoGenerateColumns"
                    Value="False" />
            <Setter Property="RowHeight"
                    Value="36" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="FontSize"
                    Value="10" />
            <Setter Property="FontWeight"
                    Value="Normal" />
            <Setter Property="Padding"
                    Value="8,6" />
            <Setter Property="BorderBrush"
                    Value="#E8D0B8" />
            <Setter Property="BorderThickness"
                    Value="0,0,0,1" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="8,0"
                                Background="{TemplateBinding Background}"
                                VerticalAlignment="Stretch">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected"
                         Value="True">
                    <Setter Property="Background"
                            Value="#F5EAD8" />
                    <Setter Property="Foreground"
                            Value="#3D2B1F" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#F5EAD8" />
                </Trigger>
                <Trigger Property="IsSelected"
                         Value="True">
                    <Setter Property="Background"
                            Value="#F5EAD8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Progress bar -->
        <Style x:Key="TeamProgressBar"
               TargetType="ProgressBar">
            <Setter Property="Height"
                    Value="6" />
            <Setter Property="Width"
                    Value="80" />
            <Setter Property="Background"
                    Value="#E8D0B8" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Height="6">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    CornerRadius="3"
                                    Background="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ================================================================ -->
        <!-- TOOLBAR                                                           -->
        <!-- ================================================================ -->
        <Border Grid.Row="0"
                Background="#F0E4D0"
                BorderBrush="#E8D0B8"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">

                <Border Style="{StaticResource TabButton}"
                        Background="#C87941">
                    <TextBlock Text="Team overview"
                               FontSize="12"
                               Foreground="#FDF6EC" />
                </Border>
                <Border Style="{StaticResource TabButton}">
                    <TextBlock Text="Overdue items"
                               FontSize="12"
                               Foreground="#9C7A5C" />
                </Border>
                <Border Style="{StaticResource TabButton}"
                        Margin="0,0,16,0">
                    <TextBlock Text="Monthly productivity"
                               FontSize="12"
                               Foreground="#9C7A5C" />
                </Border>

                <Border Width="1"
                        Background="#E8D0B8"
                        Margin="0,2,16,2" />

                <TextBlock Text="MONTH"
                           FontSize="11"
                           Foreground="#9C7A5C"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="{Binding CurrentMonth}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#3D2B1F"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0" />

                <Border Width="1"
                        Background="#E8D0B8"
                        Margin="0,2,16,2" />

                <TextBlock Text="TEAM SIZE"
                           FontSize="11"
                           Foreground="#9C7A5C"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="{Binding TeamSizeLabel}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#3D2B1F"
                           VerticalAlignment="Center" />

            </StackPanel>
        </Border>

        <!-- ================================================================ -->
        <!-- BODY                                                              -->
        <!-- ================================================================ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ============================================================ -->
            <!-- SIDEBAR                                                       -->
            <!-- ============================================================ -->
            <Border Grid.Column="0"
                    Background="#F5EAD8"
                    BorderBrush="#E8D0B8"
                    BorderThickness="0,0,1,0">
                <StackPanel>

                    <TextBlock Text="CASE MANAGERS"
                               Style="{StaticResource SidebarHeading}" />

                    <ItemsControl ItemsSource="{Binding CaseManagers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Cursor="Hand"
                                        Padding="0"
                                        BorderBrush="#C87941"
                                        BorderThickness="{Binding IsSelected,
                                            Converter={StaticResource BoolToLeftBorder}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="#EDD9C0" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                    <Setter Property="Background"
                                                            Value="#EDD9C0" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="12,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="28"
                                                Height="28"
                                                CornerRadius="14"
                                                Background="#C87941"
                                                Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Initials}"
                                                       FontSize="11"
                                                       Foreground="#FDF6EC"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="12"
                                                       Foreground="#3D2B1F" />
                                            <TextBlock Text="{Binding ClientCountLabel}"
                                                       FontSize="10"
                                                       Foreground="#9C7A5C" />
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Background="#A83220"
                                                CornerRadius="10"
                                                Padding="6,1"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding HasOverdue,
                                                    Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding OverdueCount}"
                                                       FontSize="10"
                                                       Foreground="#FDF6EC" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="QUICK FILTERS"
                               Style="{StaticResource SidebarHeading}"
                               Margin="12,16,12,4" />

                    <StackPanel Margin="12,0">
                        <TextBlock Text="&#9656; Has overdue items"
                                   Style="{StaticResource QuickFilter}" />
                        <TextBlock Text="&#9656; Below threshold"
                                   Style="{StaticResource QuickFilter}" />
                        <TextBlock Text="&#9656; Missing this month"
                                   Style="{StaticResource QuickFilter}" />
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ============================================================ -->
            <!-- MAIN CONTENT                                                  -->
            <!-- ============================================================ -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16">
                <StackPanel>

                    <!-- SUMMARY METRICS -->
                    <UniformGrid Rows="1"
                                 Columns="4"
                                 Margin="0,0,0,14">

                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="TOTAL CLIENTS"
                                           Style="{StaticResource MetricLabel}" />
                                <TextBlock Text="{Binding TotalClients}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#3D2B1F" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="OVERDUE ITEMS"
                                           Style="{StaticResource MetricLabel}" />
                                <TextBlock Text="{Binding TotalOverdue}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#A83220" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="NOTES THIS MONTH"
                                           Style="{StaticResource MetricLabel}" />
                                <TextBlock Text="{Binding TotalNotesThisMonth}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#3D2B1F" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MetricCard}"
                                Margin="0">
                            <StackPanel>
                                <TextBlock Text="AVG COMPLIANCE"
                                           Style="{StaticResource MetricLabel}" />
                                <TextBlock Text="{Binding AvgComplianceLabel}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#3A6B35" />
                            </StackPanel>
                        </Border>

                    </UniformGrid>

                    <!-- TEAM PRODUCTIVITY TABLE -->
                    <TextBlock Style="{StaticResource SectionHeading}">
                        <Run Text="TEAM PRODUCTIVITY — " />
                        <Run Text="{Binding CurrentMonth}" />
                    </TextBlock>
                    <Border BorderBrush="#E8D0B8"
                            BorderThickness="0,1,0,0"
                            Margin="0,0,0,2" />

                    <DataGrid ItemsSource="{Binding CaseManagers}"
                              SelectedItem="{Binding SelectedCaseManager}"
                              Margin="0,0,0,14">
                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Case manager"
                                                Binding="{Binding DisplayName}"
                                                Width="*" />

                            <DataGridTextColumn Header="Clients"
                                                Binding="{Binding ClientCount}"
                                                Width="60" />

                            <DataGridTextColumn Header="Notes logged"
                                                Binding="{Binding NotesThisMonth}"
                                                Width="90" />

                            <DataGridTextColumn Header="Units"
                                                Binding="{Binding UnitsThisMonth}"
                                                Width="60" />

                            <DataGridTemplateColumn Header="Progress"
                                                    Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ProgressBar Value="{Binding ProgressPercent}"
                                                     Maximum="100">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar"
                                                       BasedOn="{StaticResource TeamProgressBar}">
                                                    <Setter Property="Foreground"
                                                            Value="#C87941" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusLevel}"
                                                                     Value="Ok">
                                                            <Setter Property="Foreground"
                                                                    Value="#5A9A50" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusLevel}"
                                                                     Value="Danger">
                                                            <Setter Property="Foreground"
                                                                    Value="#A83220" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Overdue"
                                                    Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding OverdueCount}"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground"
                                                            Value="#3A6B35" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasOverdue}"
                                                                     Value="True">
                                                            <Setter Property="Foreground"
                                                                    Value="#A83220" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Status"
                                                    Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10"
                                                Padding="8,2"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"
                                                            Value="#F5DEB3" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusLevel}"
                                                                     Value="Ok">
                                                            <Setter Property="Background"
                                                                    Value="#D4EBC8" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusLevel}"
                                                                     Value="Danger">
                                                            <Setter Property="Background"
                                                                    Value="#F5CECA" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusLabel}"
                                                       FontSize="10">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground"
                                                                Value="#7A4D10" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusLevel}"
                                                                         Value="Ok">
                                                                <Setter Property="Foreground"
                                                                        Value="#2A5025" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusLevel}"
                                                                         Value="Danger">
                                                                <Setter Property="Foreground"
                                                                        Value="#7A1F1A" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- DETAIL PANEL -->
                    <Border Background="#F0E4D0"
                            BorderBrush="#E8D0B8"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <StackPanel>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding SelectedCaseManager.DetailHeading}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#3D2B1F" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SelectedCaseManager.ClientCountLabel}"
                                           FontSize="10"
                                           Foreground="#9C7A5C"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding SelectedCaseManager.UpcomingEvents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E8D0B8"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Ellipse Grid.Column="0"
                                                         Width="8"
                                                         Height="8"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill"
                                                                    Value="#C87941" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Kind}"
                                                                             Value="LateReview">
                                                                    <Setter Property="Fill"
                                                                            Value="#A83220" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}"
                                                                             Value="ScheduledForm">
                                                                    <Setter Property="Fill"
                                                                            Value="#5A9A50" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           FontSize="11"
                                                           Foreground="#3D2B1F"
                                                           VerticalAlignment="Center" />

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding DateLabel}"
                                                           FontSize="10"
                                                           Foreground="#9C7A5C"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>