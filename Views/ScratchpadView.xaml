<UserControl x:Class="Sati.Views.ScratchpadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White"
            BorderBrush="#E8D0B8"
            BorderThickness="1"
            CornerRadius="6"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,8">
                <TextBlock Text="TODAY'S WORK"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="#3D2B1F"
                           VerticalAlignment="Center" />
                <Button Command="{Binding OpenScratchpadHistoryCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="8,0,0,0"
                        Padding="4"
                        ToolTip="Browse scratchpad history">
                    <TextBlock Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Foreground="#9C7A5C" />
                </Button>
                <Button Command="{Binding DecreaseScratchpadFontCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="4,0"
                        Margin="8,0,0,0">
                    <TextBlock Text="A"
                               FontSize="11"
                               Foreground="#9C7A5C" />
                </Button>
                <Button Command="{Binding IncreaseScratchpadFontCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="4,0">
                    <TextBlock Text="A"
                               FontSize="16"
                               Foreground="#9C7A5C"
                               FontWeight="SemiBold" />
                </Button>
            </StackPanel>

            <!-- Scratchpad text area -->
            <TextBox x:Name="TodaysWorkBox"
                     Grid.Row="1"
                     FontFamily="{StaticResource NarrativeFont}"
                     FontSize="{Binding ScratchpadFontSize}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     SpellCheck.IsEnabled="True"
                     VerticalScrollBarVisibility="Auto"
                     VerticalAlignment="Stretch"
                     Text="{Binding ScratchpadContent, UpdateSourceTrigger=PropertyChanged}"
                     BorderThickness="0"
                     Margin="0"
                     Background="Transparent"
                     KeyDown="TodaysWorkBox_KeyDown" />
        </Grid>
    </Border>
</UserControl>