<Window x:Class="Sati.ScratchpadHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scratchpad History"
        Height="600"
        Width="700"
        MinHeight="400"
        MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Background="#FDF6EC">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding"
                    Value="8,4" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <TextBlock Grid.Row="0"
                   Text="SEARCH HISTORY"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="#9C7A5C"
                   Margin="0,0,0,5" />

        <TextBox Grid.Row="1"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12" />

        <!-- Entry grid -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6">
            <DataGrid ItemsSource="{Binding EntriesView}"
                      SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="White"
                      AlternatingRowBackground="#FDF6EC"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F0E0D0"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding Date, StringFormat={}{0:MMM d yyyy}}"
                                        Width="120" />
                    <DataGridTextColumn Header="Entry"
                                        Binding="{Binding ContentPreview}"
                                        Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Full content preview -->
        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <TextBox Text="{Binding SelectedContent, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="Transparent" />
        </Border>
    </Grid>
</Window>