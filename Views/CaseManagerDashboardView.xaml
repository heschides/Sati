<UserControl x:Class="Sati.Views.CaseManagerDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Sati.Views"
             Background="#FDF6EC"
             TextElement.FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ SUB-NAV TOOLBAR ═══ -->
        <Border Grid.Row="0"
                Background="#F0E4D0"
                BorderBrush="#E8D0B8"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <StackPanel Orientation="Horizontal">

                <Border Cursor="Hand"
                        CornerRadius="4"
                        Padding="12,4"
                        Margin="0,0,4,0">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding NavigateToOverviewCommand}" />
                    </Border.InputBindings>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDashboardSubActive}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="#C87941" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="Overview"
                               FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="#9C7A5C" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDashboardSubActive}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="#FDF6EC" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <Border Cursor="Hand"
                        CornerRadius="4"
                        Padding="12,4"
                        Margin="0,0,4,0">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding NavigateToClientsCommand}" />
                    </Border.InputBindings>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsClientsSubActive}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="#C87941" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="Clients"
                               FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="#9C7A5C" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsClientsSubActive}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="#FDF6EC" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <Border Cursor="Hand"
                        CornerRadius="4"
                        Padding="12,4"
                        Margin="0,0,4,0">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding NavigateToNotesLogCommand}" />
                    </Border.InputBindings>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNotesLogSubActive}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="#C87941" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="Notes"
                               FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="#9C7A5C" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNotesLogSubActive}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="#FDF6EC" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <Border Cursor="Hand"
                        CornerRadius="4"
                        Padding="12,4"
                        Margin="0,0,4,0">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding NavigateToMatrixCommand}" />
                    </Border.InputBindings>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMatrixSubActive}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="#C87941" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="Caseload Matrix"
                               FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="#9C7A5C" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMatrixSubActive}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="#FDF6EC" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

            </StackPanel>
        </Border>

        <!-- ═══ CONTENT AREA ═══ -->
        <Grid Grid.Row="1">

            <!-- Overview — shown when CurrentSubViewModel is null -->
            <views:CaseManagerDashboardContentView Visibility="{Binding IsDashboardSubActive,
                    Converter={StaticResource BoolToVisibilityConverter}}" />

            <!-- Other sub-tabs -->
            <ContentControl Content="{Binding CurrentSubViewModel}"
                            Visibility="{Binding IsSubViewActive,
                    Converter={StaticResource BoolToVisibilityConverter}}" />

        </Grid>
    </Grid>
</UserControl>