<UserControl x:Class="Sati.Views.ClientsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sati"
        xmlns:converters="clr-namespace:Sati.Converters"
        Background="#FDF6EC">

    <UserControl.Resources>
        <converters:BoolToWidthConverter x:Key="BoolToWidthConverter" />
        <converters:BoolToWidthConverter x:Key="SpacerWidthConverter"
                                         TrueWidth="16"
                                         FalseWidth="0" />

        <Style x:Key="LabelStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="Margin"
                    Value="0,0,0,5" />
        </Style>

        <Style x:Key="SectionHeader"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,6" />
        </Style>


        <Style x:Key="IconButton"
               TargetType="Button">
            <Setter Property="Width"
                    Value="32" />
            <Setter Property="Height"
                    Value="32" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#E8D0B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding IsEntryPanelOpen, Converter={StaticResource BoolToWidthConverter}}" />
            <ColumnDefinition Width="{Binding IsEntryPanelOpen, Converter={StaticResource SpacerWidthConverter}}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ ENTRY FORM (left) ═══ -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16"
                Visibility="{Binding IsEntryPanelOpen, 
            Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="ADD CLIENT"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="#3D2B1F"
                           Margin="0,0,0,16" />

                <TextBlock Text="FIRST NAME"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="LAST NAME"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="BIRTHDAY"
                           Style="{StaticResource LabelStyle}" />
                <DatePicker SelectedDate="{Binding BirthDate, Mode=TwoWay}" />

                <TextBlock Text="WAIVER"
                           Style="{StaticResource LabelStyle}" />
                <ComboBox ItemsSource="{Binding Waivers}"
                          SelectedItem="{Binding Waiver, Mode=TwoWay}" />

                <TextBlock Text="EFFECTIVE DATE"
                           Style="{StaticResource LabelStyle}" />
                <Grid Margin="0,0,0,10"
                      IsEnabled="{Binding HasWaiver}">
                    <TextBox Text="{Binding EffectiveDateText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="MM/DD"
                               Foreground="#C0A898"
                               FontSize="13"
                               Margin="9,4"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EffectiveDateText}"
                                                 Value="">
                                        <Setter Property="Visibility"
                                                Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock Text="BIO"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding Bio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="100" />

                <Button Content="{Binding SubmitButtonLabel}"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SubmitCommand}" />

                <Button Content="Remove Selected"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding RemoveSelectedPersonCommand}" />
            </StackPanel>
        </Border>

        <!-- ═══ RIGHT PANEL ═══ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="260" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ═══ CLIENT ROSTER ═══ -->
            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#E8D0B8"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="16,12,16,8">
                        <TextBlock Text="CLIENTS"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#3D2B1F"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0" />
                        <Button Style="{StaticResource IconButton}"
                                Command="{Binding OpenEntryPanelCommand}"
                                ToolTip="Add new client">
                            <TextBlock Text="&#xE710;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="#9C7A5C" />
                        </Button>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding People}"
                              SelectedItem="{Binding SelectedPerson, Mode=TwoWay}"
                              MouseDoubleClick="DataGrid_MouseDoubleClick"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="Transparent"
                              BorderThickness="0"
                              RowBackground="White"
                              AlternatingRowBackground="#FDF6EC"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0E0D0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="First Name"
                                                Binding="{Binding FirstName}"
                                                Width="*" />
                            <DataGridTextColumn Header="Last Name"
                                                Binding="{Binding LastName}"
                                                Width="*" />
                            <DataGridTextColumn Header="Waiver"
                                                Binding="{Binding Waiver}"
                                                Width="*" />
                            <DataGridTextColumn Header="Effective Date"
                                                Binding="{Binding EffectiveDate, StringFormat={}{0:MM/dd/yyyy}}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ═══ CLIENT DETAIL PANEL ═══ -->
            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#E8D0B8"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16"
                    Visibility="{Binding HasSelectedPerson,
                        Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- CLIENT INFO -->
                    <StackPanel Grid.Column="0"
                                Grid.Row="0"
                                Grid.RowSpan="3">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,12">
                            <TextBlock Text="{Binding SelectedPerson.FullName}"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#3D2B1F" />
                        </StackPanel>

                        <TextBlock Text="WAIVER"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding SelectedPerson.Waiver}"
                                   Foreground="#3D2B1F"
                                   FontSize="13"
                                   Margin="0,0,0,10" />

                        <TextBlock Text="EFFECTIVE DATE"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding SelectedPerson.EffectiveDate, StringFormat={}{0:MM/dd/yyyy}}"
                                   Foreground="#3D2B1F"
                                   FontSize="13"
                                   Margin="0,0,0,10" />

                        <TextBlock Text="DATE OF BIRTH"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding SelectedPerson.BirthDate, StringFormat={}{0:MM/dd/yyyy}}"
                                   Foreground="#3D2B1F"
                                   FontSize="13"
                                   Margin="0,0,0,10" />

                        <TextBlock Text="BIO"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding SelectedPerson.Bio}"
                                   Foreground="#3D2B1F"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- FORMS COMPLIANCE -->
                    <Grid Grid.Column="2"
                          Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <TextBlock Text="FORMS"
                                       Style="{StaticResource SectionHeader}"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center" />
                            <Button Style="{StaticResource IconButton}"
                                    Command="{Binding ToggleComplianceOverrideCommand}"
                                    ToolTip="Toggle compliance editing">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Foreground="#9C7A5C">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"
                                                    Value="&#xE72E;" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AllowComplianceOverride}"
                                                             Value="True">
                                                    <Setter Property="Text"
                                                            Value="&#xE785;" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="90-Day Reviews"
                                           Style="{StaticResource SectionHeader}" />
                                <StackPanel Grid.Row="1"
                                            Grid.Column="0">
                                    <CheckBox Content="Quarter 1"
                                              IsChecked="{Binding Q1RCompliant, Mode=OneWay}"
                                              IsEnabled="{Binding AllowComplianceOverride}"
                                              Command="{Binding ToggleFormCommand}"
                                              CommandParameter="{x:Static local:FormType.Q1R}" />
                                    <TextBlock Text="{Binding Q1RDueDate, StringFormat={}{0:MM/dd/yy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="11"
                                               Margin="20,1,0,4" />
                                </StackPanel>
                                <StackPanel Grid.Row="2"
                                            Grid.Column="0">
                                    <CheckBox Content="Quarter 2"
                                              IsChecked="{Binding Q2RCompliant, Mode=OneWay}"
                                              IsEnabled="{Binding AllowComplianceOverride}"
                                              Command="{Binding ToggleFormCommand}"
                                              CommandParameter="{x:Static local:FormType.Q2R}" />
                                    <TextBlock Text="{Binding Q2RDueDate, StringFormat={}{0:MM/dd/yy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="11"
                                               Margin="20,1,0,4" />
                                </StackPanel>
                                <StackPanel Grid.Row="3"
                                            Grid.Column="0">
                                    <CheckBox Content="Quarter 3"
                                              IsChecked="{Binding Q3RCompliant, Mode=OneWay}"
                                              IsEnabled="{Binding AllowComplianceOverride}"
                                              Command="{Binding ToggleFormCommand}"
                                              CommandParameter="{x:Static local:FormType.Q3R}" />
                                    <TextBlock Text="{Binding Q3RDueDate, StringFormat={}{0:MM/dd/yy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="11"
                                               Margin="20,1,0,4" />
                                </StackPanel>
                                <StackPanel Grid.Row="4"
                                            Grid.Column="0">
                                    <CheckBox Content="Quarter 4"
                                              IsChecked="{Binding Q4RCompliant, Mode=OneWay}"
                                              IsEnabled="{Binding AllowComplianceOverride}"
                                              Command="{Binding ToggleFormCommand}"
                                              CommandParameter="{x:Static local:FormType.Q4R}" />
                                    <TextBlock Text="{Binding Q4RDueDate, StringFormat={}{0:MM/dd/yy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="11"
                                               Margin="20,1,0,4" />
                                </StackPanel>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           Text="Annual Forms"
                                           Style="{StaticResource SectionHeader}" />
                                <StackPanel Grid.Row="1"
                                            Grid.Column="2">
                                    <CheckBox Content="PCP"
                                              IsChecked="{Binding PcpCompliant, Mode=OneWay}"
                                              IsEnabled="{Binding AllowComplianceOverride}"
                                              Command="{Binding ToggleFormCommand}"
                                              CommandParameter="{x:Static local:FormType.PCP}" />
                                    <TextBlock Text="{Binding PcpDueDate, StringFormat={}{0:MM/dd/yy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="11"
                                               Margin="20,1,0,4" />
                                </StackPanel>
                                <StackPanel Grid.Row="2"
                                            Grid.Column="2">
                                    <CheckBox Content="Comp Assessment"
                                              IsChecked="{Binding CompAssessmentCompliant, Mode=OneWay}"
                                              IsEnabled="{Binding AllowComplianceOverride}"
                                              Command="{Binding ToggleFormCommand}"
                                              CommandParameter="{x:Static local:FormType.ComprehensiveAssessment}" />
                                    <TextBlock Text="{Binding CompAssessmentDueDate, StringFormat={}{0:MM/dd/yy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="11"
                                               Margin="20,1,0,4" />
                                </StackPanel>
                                <StackPanel Grid.Row="3"
                                            Grid.Column="2">
                                    <CheckBox Content="Reclassification"
                                              IsChecked="{Binding ReclassificationCompliant, Mode=OneWay}"
                                              IsEnabled="{Binding AllowComplianceOverride}"
                                              Command="{Binding ToggleFormCommand}"
                                              CommandParameter="{x:Static local:FormType.Reclassification}" />
                                    <TextBlock Text="{Binding ReclassificationDueDate, StringFormat={}{0:MM/dd/yy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="11"
                                               Margin="20,1,0,4" />
                                </StackPanel>
                                <StackPanel Grid.Row="4"
                                            Grid.Column="2">
                                    <CheckBox Content="Safety Plan"
                                              IsChecked="{Binding SafetyPlanCompliant, Mode=OneWay}"
                                              IsEnabled="{Binding AllowComplianceOverride}"
                                              Command="{Binding ToggleFormCommand}"
                                              CommandParameter="{x:Static local:FormType.SafetyPlan}" />
                                    <TextBlock Text="{Binding SafetyPlanDueDate, StringFormat={}{0:MM/dd/yy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="11"
                                               Margin="20,1,0,4" />
                                </StackPanel>
                                <StackPanel Grid.Row="5"
                                            Grid.Column="2">
                                    <CheckBox Content="Privacy Practices"
                                              IsChecked="{Binding PrivacyPracticesCompliant, Mode=OneWay}"
                                              IsEnabled="{Binding AllowComplianceOverride}"
                                              Command="{Binding ToggleFormCommand}"
                                              CommandParameter="{x:Static local:FormType.PrivacyPractices}" />
                                    <TextBlock Text="{Binding PrivacyPracticesDueDate, StringFormat={}{0:MM/dd/yy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="11"
                                               Margin="20,1,0,4" />
                                </StackPanel>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="4"
                                           Text="Releases"
                                           Style="{StaticResource SectionHeader}" />
                                <StackPanel Grid.Row="1"
                                            Grid.Column="4">
                                    <CheckBox Content="DHHS"
                                              IsChecked="{Binding ReleaseDhhsCompliant, Mode=OneWay}"
                                              IsEnabled="{Binding AllowComplianceOverride}"
                                              Command="{Binding ToggleFormCommand}"
                                              CommandParameter="{x:Static local:FormType.Release_DHHS}" />
                                    <TextBlock Text="{Binding ReleaseDhhsDueDate, StringFormat={}{0:MM/dd/yy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="11"
                                               Margin="20,1,0,4" />
                                </StackPanel>
                                <StackPanel Grid.Row="2"
                                            Grid.Column="4">
                                    <CheckBox Content="Agency"
                                              IsChecked="{Binding ReleaseAgencyCompliant, Mode=OneWay}"
                                              IsEnabled="{Binding AllowComplianceOverride}"
                                              Command="{Binding ToggleFormCommand}"
                                              CommandParameter="{x:Static local:FormType.Release_Agency}" />
                                    <TextBlock Text="{Binding ReleaseAgencyDueDate, StringFormat={}{0:MM/dd/yy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="11"
                                               Margin="20,1,0,4" />
                                </StackPanel>
                                <StackPanel Grid.Row="3"
                                            Grid.Column="4">
                                    <CheckBox Content="Medical"
                                              IsChecked="{Binding ReleaseMedicalCompliant, Mode=OneWay}"
                                              IsEnabled="{Binding AllowComplianceOverride}"
                                              Command="{Binding ToggleFormCommand}"
                                              CommandParameter="{x:Static local:FormType.Release_Medical}" />
                                    <TextBlock Text="{Binding ReleaseMedicalDueDate, StringFormat={}{0:MM/dd/yy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="11"
                                               Margin="20,1,0,4" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <!-- NOTES HISTORY -->
                    <Grid Grid.Column="2"
                          Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="NOTES"
                                   Style="{StaticResource SectionHeader}" />

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding SelectedPersonNotes}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowBackground="White"
                                  AlternatingRowBackground="#FDF6EC"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F0E0D0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date"
                                                    Binding="{Binding EventDate, StringFormat={}{0:MM/dd}}"
                                                    Width="60" />
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="80" />
                                <DataGridTextColumn Header="Narrative"
                                                    Binding="{Binding Narrative}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>