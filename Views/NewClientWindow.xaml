<Window x:Class="Sati.NewClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sati"
        mc:Ignorable="d"
        Title="Client List"
        Height="650"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#FDF6EC">

    <Window.Resources>
        <Style x:Key="LabelStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="Margin"
                    Value="0,0,0,5" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding"
                    Value="8,4" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding"
                    Value="6,4" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
        </Style>

        <Style x:Key="PrimaryButton"
               TargetType="Button">
            <Setter Property="Height"
                    Value="36" />
            <Setter Property="Background"
                    Value="#C87941" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#A85E28" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#8A4D20" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton"
               TargetType="Button">
            <Setter Property="Height"
                    Value="36" />
            <Setter Property="Background"
                    Value="#E8D0B8" />
            <Setter Property="Foreground"
                    Value="#8A4D20" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#D4A882" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ ENTRY FORM (left) ═══ -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16">
            <StackPanel>
                <TextBlock Text="ADD CLIENT"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="#3D2B1F"
                           Margin="0,0,0,16" />

                <TextBlock Text="FIRST NAME"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="LAST NAME"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="BIRTHDAY"
                           Style="{StaticResource LabelStyle}" />
                <DatePicker SelectedDate="{Binding BirthDate, Mode=TwoWay}" />

                <TextBlock Text="WAIVER"
                           Style="{StaticResource LabelStyle}" />
                <ComboBox ItemsSource="{Binding Waivers}"
                          SelectedItem="{Binding Waiver, Mode=TwoWay}" />
                <TextBlock Text="EFFECTIVE DATE"
                           Style="{StaticResource LabelStyle}" />
                <Grid Margin="0,0,0,10"
                      IsEnabled="{Binding HasWaiver}">
                    <TextBox Text="{Binding EffectiveDateText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="MM/DD"
                               Foreground="#C0A898"
                               FontSize="13"
                               Margin="9,4"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EffectiveDateText}"
                                                 Value="">
                                        <Setter Property="Visibility"
                                                Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock Text="BIO"
                           Style="{StaticResource LabelStyle}" />
                <TextBox Text="{Binding Bio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="100" />

                <Button Content="{Binding SubmitButtonLabel}"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SubmitCommand}" />

                <Button Content="Remove Selected"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding RemoveSelectedPersonCommand}" />
            </StackPanel>
        </Border>

        <!-- ═══ CLIENT LIST (right) ═══ -->
        <Border Grid.Column="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="CLIENTS"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="#3D2B1F"
                           Margin="16,16,16,8" />

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding People}"
                          SelectedItem="{Binding SelectedPerson, Mode=TwoWay}"
                          MouseDoubleClick="DataGrid_MouseDoubleClick"
                          AutoGenerateColumns="True"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="White"
                          AlternatingRowBackground="#FDF6EC"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F0E0D0"
                          Margin="0" />
            </Grid>
        </Border>
    </Grid>
</Window>