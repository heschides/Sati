<Window x:Class="Sati.Views.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Notes"
        Height="600"
        Width="860"
        WindowStartupLocation="CenterOwner"
        Background="#FDF6EC">

    <Window.Resources>
        <Style x:Key="LabelStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="Margin"
                    Value="0,0,0,4" />
        </Style>
        <Style x:Key="SectionHeader"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding"
                    Value="8,4" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding"
                    Value="6,4" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Filter bar -->
            <RowDefinition Height="*" />
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ═══ FILTER BAR ═══ -->
        <!-- ═══ FILTER BAR ═══ -->
        <Grid Grid.Row="0"
              Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Client dropdown -->
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding FilterPeople}"
                      SelectedItem="{Binding SelectedFilterPerson, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding FullName, FallbackValue='All Clients'}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Status dropdown -->
            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding FilterStatusOptions}"
                      SelectedItem="{Binding FilterStatus, Mode=TwoWay}"
                      DisplayMemberPath="Label">
            </ComboBox>

            <!-- Search box -->
            <TextBox Grid.Column="4"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,4">
                <TextBox.Style>
                    <Style TargetType="TextBox"
                           BasedOn="{StaticResource {x:Type TextBox}}">
                        <Style.Triggers>
                            <Trigger Property="Text"
                                     Value="">
                                <!-- Placeholder handled by overlay below -->
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Grid>

        <!-- ═══ CONTENT: DATAGRID + DETAIL ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Notes DataGrid -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E8D0B8"
                    BorderThickness="1"
                    CornerRadius="6">
                <DataGrid ItemsSource="{Binding NotesView}"
                          SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="White"
                          AlternatingRowBackground="#FDF6EC"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F0E0D0"
                          HeadersVisibility="Column"
                          SelectionMode="Single">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Mark Note Logged"
                                      Command="{Binding MarkNoteLoggedCommand}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Client"
                                            Binding="{Binding Person.FullName}"
                                            Width="*" />
                        <DataGridTextColumn Header="Date"
                                            Binding="{Binding EventDate, StringFormat={}{0:MM/dd}}"
                                            Width="60" />
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="80" />
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding NoteType}"
                                            Width="80" />
                        <DataGridTextColumn Header="Units"
                                            Binding="{Binding Units}"
                                            Width="50" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Note Detail Panel -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#E8D0B8"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16">
                <Grid>
                    <!-- Placeholder when nothing is selected -->
                    <TextBlock Text="Select a note to view details."
                               Foreground="#C0A080"
                               FontSize="13"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNote}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Detail content -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility"
                                        Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNote}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="NOTE DETAIL"
                                   Style="{StaticResource SectionHeader}" />
                        <Separator Background="#E8D0B8"
                                   Margin="0,0,0,10" />

                        <TextBlock Text="CLIENT"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding SelectedNote.Person.FullName}"
                                   FontSize="13"
                                   Foreground="#3D2B1F"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="TYPE"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding SelectedNote.NoteType}"
                                   FontSize="13"
                                   Foreground="#3D2B1F"
                                   Margin="0,0,0,10" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DATE"
                                           Style="{StaticResource LabelStyle}" />
                                <TextBlock Text="{Binding SelectedNote.EventDate, StringFormat={}{0:MM/dd/yyyy}}"
                                           FontSize="13"
                                           Foreground="#3D2B1F" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="STATUS"
                                           Style="{StaticResource LabelStyle}" />
                                <TextBlock Text="{Binding SelectedNote.Status}"
                                           FontSize="13"
                                           Foreground="#3D2B1F" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="UNITS"
                                           Style="{StaticResource LabelStyle}" />
                                <TextBlock Text="{Binding SelectedNote.Units}"
                                           FontSize="13"
                                           Foreground="#3D2B1F" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="NARRATIVE"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox Text="{Binding SelectedNote.Narrative, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="300"
                                 Background="#FDF6EC"
                                 BorderBrush="#E8D0B8"
                                 Padding="8" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>