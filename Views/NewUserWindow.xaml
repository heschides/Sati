<Window x:Class="Sati.Views.NewUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sati.Views"
        mc:Ignorable="d"
        Title="Create Account"
        Height="640"
        Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FDF6EC">

    <Window.Resources>
        <Style x:Key="LabelStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="Margin"
                    Value="0,0,0,5" />
        </Style>

        <Style x:Key="InputStyle"
               TargetType="Control">
            <Setter Property="Height"
                    Value="36" />
            <Setter Property="Padding"
                    Value="10,0" />
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,16" />
        </Style>

        <Style x:Key="PrimaryButton"
               TargetType="Button">
            <Setter Property="Height"
                    Value="40" />
            <Setter Property="Background"
                    Value="#C87941" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#A85E28" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#8A4D20" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="40">
        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="Create User"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#3D2B1F"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />
            <TextBlock Text="Sati Case Management"
                       FontSize="12"
                       Foreground="#9C7A5C"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32" />

            <TextBlock Text="USERNAME"
                       Style="{StaticResource LabelStyle}" />
            <TextBox Style="{StaticResource InputStyle}"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" />

            <TextBlock Text="DISPLAY NAME"
                       Style="{StaticResource LabelStyle}" />
            <TextBox Style="{StaticResource InputStyle}"
                     Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" />

            <TextBlock Text="PASSWORD"
                       Style="{StaticResource LabelStyle}" />
            <PasswordBox x:Name="PasswordInit"
                         Style="{StaticResource InputStyle}"
                         PasswordChanged="PasswordInit_PasswordChanged"
                         VerticalContentAlignment="Center" />

            <TextBlock Text="CONFIRM PASSWORD"
                       Style="{StaticResource LabelStyle}" />
            <PasswordBox x:Name="PasswordConfirm"
                         Style="{StaticResource InputStyle}"
                         PasswordChanged="PasswordConfirm_PasswordChanged"
                         VerticalContentAlignment="Center" />

            <TextBlock Text="SUPERVISOR"
                       Style="{StaticResource LabelStyle}" />
            <ComboBox Style="{StaticResource InputStyle}"
                      ItemsSource="{Binding Supervisors}"
                      SelectedItem="{Binding SelectedSupervisor}"
                      DisplayMemberPath="DisplayName"
                      VerticalContentAlignment="Center" />

            <Button Content="Create Account"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding CreateUserCommand}" />

        </StackPanel>
    </Border>
</Window>