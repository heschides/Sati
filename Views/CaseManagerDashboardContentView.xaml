<UserControl x:Class="Sati.Views.CaseManagerDashboardContentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sati="clr-namespace:Sati"
             Background="#FDF6EC"
             TextElement.FontFamily="{StaticResource AppFont}">

    <!--
        LAYOUT: 5 columns (3 content + 2 spacers), 3 rows
        ┌─────────────┬───┬─────────────┬───┬─────────────┐
        │ Col 0       │   │ Col 2       │   │ Col 4       │
        ├─────────────┤   ├─────────────┤   ├─────────────┤
        │ Row 0       │   │ Row 0       │   │ Rows 0-1    │
        │ Toolbar     │   │ Filter bar  │   │ Productivity│
        ├─────────────┤   ├─────────────┤   ├─────────────┤
        │ Rows 1-2    │   │ Row 1       │   │ Row 2       │
        │ Note entry  │   │ Notes grid  │   │ Upcoming    │
        │ form        │   ├─────────────┤   │ Tasks       │
        │             │   │ Row 2       │   │             │
        │             │   │ Forms +     │   │             │
        │             │   │ Productivity│   │             │
        └─────────────┴───┴─────────────┴───┴─────────────┘
    -->
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width=".55*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width=".65*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ COL 0 ROW 0: TOOLBAR ═══ -->
        <Grid Grid.Column="0"
              Grid.Row="0"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
            </Grid.ColumnDefinitions>

            <Button x:Name="SchedulerButton"
                    Grid.Column="2"
                    Style="{StaticResource SmallButton}"
                    ToolTip="Scheduler"
                    Width="28"
                    Command="{Binding OpenSchedulerCommand}"
                    Background="Transparent"
                    Padding="0">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE787;"
                           FontSize="14"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
            </Button>
        </Grid>

        <!-- Scheduler popup — anchored to SchedulerButton by name, IsOpen binds directly -->
        <Popup x:Name="SchedulerPopup"
               PlacementTarget="{Binding ElementName=SchedulerButton}"
               Placement="Bottom"
               IsOpen="{Binding DataContext.IsSchedulerOpen,
                RelativeSource={RelativeSource AncestorType=UserControl}}"
               DataContext="{Binding Scheduler}"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Slide">
            <Border Background="White"
                    BorderBrush="#E8D0B8"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16">
                <StackPanel Width="320">

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="◀"
                                Style="{StaticResource SmallButton}"
                                Command="{Binding PreviousMonthCommand}"
                                Width="28" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding MonthLabel}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#3D2B1F"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="2"
                                Content="▶"
                                Style="{StaticResource SmallButton}"
                                Command="{Binding NextMonthCommand}"
                                Width="28" />
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Mon"
                                   Style="{StaticResource LabelStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="Tue"
                                   Style="{StaticResource LabelStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="Wed"
                                   Style="{StaticResource LabelStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="3"
                                   Text="Thu"
                                   Style="{StaticResource LabelStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="4"
                                   Text="Fri"
                                   Style="{StaticResource LabelStyle}"
                                   HorizontalAlignment="Center" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Tiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="2"
                                        Command="{Binding DataContext.ToggleTileCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding IsInteractable}"
                                        Background="{Binding IsExcluded,
                                            Converter={StaticResource BoolToTileColorConverter}}"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Height="44">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                <Grid>
                                                    <TextBlock Text="{Binding Letter}"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="#3D2B1F"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Date, StringFormat={}{0:d}}"
                                                               FontSize="8"
                                                               Foreground="#9C7A5C"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"
                                                               Margin="0,0,3,2" />
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="DAYS SCHEDULED"
                                   Style="{StaticResource LabelStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DaysScheduled}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#3D2B1F" />
                    </Grid>

                </StackPanel>
            </Border>
        </Popup>

        <!-- ═══ COL 0 ROWS 1-2: NOTE ENTRY FORM ═══ -->
        <Border Grid.Column="0"
                Grid.Row="1"
                Grid.RowSpan="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="NEW NOTE"
                           Grid.Row="0"
                           Style="{StaticResource SectionHeader}" />

                <TextBlock Text="CLIENT"
                           Grid.Row="1"
                           Style="{StaticResource LabelStyle}" />
                <ComboBox Grid.Row="2"
                          ItemsSource="{Binding People}"
                          SelectedItem="{Binding SelectedPerson}"
                          DisplayMemberPath="FullName" />

                <TextBlock Text="STATUS"
                           Grid.Row="3"
                           Style="{StaticResource LabelStyle}" />
                <ComboBox Grid.Row="4"
                          ItemsSource="{Binding NoteStatusOptions}"
                          SelectedItem="{Binding Status, Mode=TwoWay}" />

                <Grid Margin="0,0,0,10"
                      Grid.Row="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="75" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="NOTE TYPE"
                               Style="{StaticResource LabelStyle}"
                               Grid.Row="0"
                               Grid.Column="0"
                               Grid.ColumnSpan="2" />
                    <RadioButton Grid.Row="1"
                                 Grid.Column="1"
                                 Content="Visit"
                                 Margin="0,0,12,4"
                                 Foreground="#3D2B1F"
                                 GroupName="NoteType"
                                 IsChecked="{Binding SelectedNoteType,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=Visit}" />
                    <RadioButton Grid.Row="1"
                                 Grid.Column="3"
                                 Content="Contact"
                                 Margin="0,0,12,4"
                                 Foreground="#3D2B1F"
                                 GroupName="NoteType"
                                 IsChecked="{Binding SelectedNoteType,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=Contact}" />
                    <RadioButton Grid.Row="2"
                                 Grid.Column="1"
                                 Content="Other"
                                 Margin="0,0,12,4"
                                 Foreground="#3D2B1F"
                                 GroupName="NoteType"
                                 IsChecked="{Binding SelectedNoteType,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=Other}" />
                    <RadioButton Grid.Row="2"
                                 Grid.Column="3"
                                 Content="Form"
                                 Margin="0,0,8,4"
                                 Foreground="#3D2B1F"
                                 GroupName="NoteType"
                                 IsChecked="{Binding SelectedNoteType,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=Form}" />
                    <ComboBox Grid.Row="3"
                              Grid.ColumnSpan="4"
                              ItemsSource="{Binding FormTypes}"
                              SelectedItem="{Binding SelectedFormType, Mode=TwoWay}"
                              Visibility="{Binding IsFormNote,
                                  Converter={StaticResource BoolToVisibilityConverter}}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="7">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="MINUTES"
                               Grid.Row="0"
                               Style="{StaticResource LabelStyle}" />
                    <TextBox Grid.Row="1"
                             Text="{Binding Minutes}" />

                    <TextBlock Text="DATE"
                               Grid.Row="2"
                               Style="{StaticResource LabelStyle}" />
                    <DatePicker Grid.Row="3"
                                SelectedDate="{Binding EventDate}" />

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="NARRATIVE"
                                   Style="{StaticResource LabelStyle}" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal">
                            <Button Command="{Binding DecreaseNarrativeFontCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="4,0">
                                <TextBlock Text="A"
                                           FontSize="11"
                                           Foreground="#9C7A5C" />
                            </Button>
                            <Button Command="{Binding IncreaseNarrativeFontCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="4,0">
                                <TextBlock Text="A"
                                           FontSize="16"
                                           Foreground="#9C7A5C"
                                           FontWeight="SemiBold" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <TextBox Grid.Row="5"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             SpellCheck.IsEnabled="True"
                             FontFamily="{StaticResource NarrativeFont}"
                             FontSize="{Binding NarrativeFontSize}"
                             Text="{Binding Narrative}" />
                </Grid>

                <Button Grid.Row="8"
                        Content="Submit Note"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SubmitNoteCommand}"
                        Margin="0,10,0,0" />
            </Grid>
        </Border>

        <!-- ═══ COL 2 ROW 0: FILTER BAR ═══ -->
        <Grid Grid.Row="0"
              Grid.Column="2"
              Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="160" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="FILTER NOTES"
                       Style="{StaticResource LabelStyle}" />
            <TextBlock Grid.Row="0"
                       Grid.Column="2"
                       Text="FILTER STATUS"
                       Style="{StaticResource LabelStyle}" />

            <TextBox x:Name="SearchTextBox"
                     Grid.Row="1"
                     Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox Grid.Row="1"
                      Grid.Column="2"
                      Height="{Binding ActualHeight, ElementName=SearchTextBox}"
                      ItemsSource="{Binding NoteStatusOptions}"
                      SelectedItem="{Binding FilterStatus}" />
        </Grid>

        <!-- ═══ COL 2 ROW 1: NOTES DATAGRID ═══ -->
        <Border Grid.Column="2"
                Grid.Row="1"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Margin="0,0,0,12">
            <DataGrid ItemsSource="{Binding NotesView}"
                      SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                      MouseDoubleClick="DataGrid_MouseDoubleClick"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="White"
                      AlternatingRowBackground="#FDF6EC"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F0E0D0"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding EventDate, StringFormat={}{0:MM/dd}}"
                                        Width="60" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="90" />
                    <DataGridTextColumn Header="Units"
                                        Binding="{Binding Units}"
                                        Width="50" />
                    <DataGridTextColumn Header="Type"
                                        Binding="{Binding NoteType}"
                                        Width="80" />
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Delete Note"
                                  Command="{Binding DeleteNoteCommand}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Border>

        <!-- ═══ COL 2 ROW 2: FORMS CHECKLIST + MONTHLY PRODUCTIVITY ═══ -->
        <Border Grid.Column="2"
                Grid.Row="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,12">
            <StackPanel>

                <!-- Forms checklist -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="90-Day Reviews"
                               Style="{StaticResource SectionHeader}" />
                    <CheckBox Grid.Row="1"
                              Grid.Column="0"
                              Content="Quarter 1"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6"
                              IsChecked="{Binding Q1RCompliant, Mode=OneWay}"
                              Command="{Binding ToggleFormCommand}"
                              CommandParameter="{x:Static sati:FormType.Q1R}" />
                    <CheckBox Grid.Row="2"
                              Grid.Column="0"
                              Content="Quarter 2"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6"
                              IsChecked="{Binding Q2RCompliant, Mode=OneWay}"
                              Command="{Binding ToggleFormCommand}"
                              CommandParameter="{x:Static sati:FormType.Q2R}" />
                    <CheckBox Grid.Row="3"
                              Grid.Column="0"
                              Content="Quarter 3"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6"
                              IsChecked="{Binding Q3RCompliant, Mode=OneWay}"
                              Command="{Binding ToggleFormCommand}"
                              CommandParameter="{x:Static sati:FormType.Q3R}" />
                    <CheckBox Grid.Row="4"
                              Grid.Column="0"
                              Content="Quarter 4"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6"
                              IsChecked="{Binding Q4RCompliant, Mode=OneWay}"
                              Command="{Binding ToggleFormCommand}"
                              CommandParameter="{x:Static sati:FormType.Q4R}" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="Annual Forms"
                               Style="{StaticResource SectionHeader}" />
                    <CheckBox Grid.Row="1"
                              Grid.Column="2"
                              Content="PCP"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6"
                              IsChecked="{Binding PcpCompliant, Mode=OneWay}"
                              Command="{Binding ToggleFormCommand}"
                              CommandParameter="{x:Static sati:FormType.PCP}" />
                    <CheckBox Grid.Row="2"
                              Grid.Column="2"
                              Content="Comp Assessment"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6"
                              IsChecked="{Binding CompAssessmentCompliant, Mode=OneWay}"
                              Command="{Binding ToggleFormCommand}"
                              CommandParameter="{x:Static sati:FormType.ComprehensiveAssessment}" />
                    <CheckBox Grid.Row="3"
                              Grid.Column="2"
                              Content="Reclassification"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6"
                              IsChecked="{Binding ReclassificationCompliant, Mode=OneWay}"
                              Command="{Binding ToggleFormCommand}"
                              CommandParameter="{x:Static sati:FormType.Reclassification}" />
                    <CheckBox Grid.Row="4"
                              Grid.Column="2"
                              Content="Safety Plan"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6"
                              IsChecked="{Binding SafetyPlanCompliant, Mode=OneWay}"
                              Command="{Binding ToggleFormCommand}"
                              CommandParameter="{x:Static sati:FormType.SafetyPlan}" />
                    <CheckBox Grid.Row="5"
                              Grid.Column="2"
                              Content="Privacy Practices"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6"
                              IsChecked="{Binding PrivacyPracticesCompliant, Mode=OneWay}"
                              Command="{Binding ToggleFormCommand}"
                              CommandParameter="{x:Static sati:FormType.PrivacyPractices}" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="4"
                               Text="Releases"
                               Style="{StaticResource SectionHeader}" />
                    <CheckBox Grid.Row="1"
                              Grid.Column="4"
                              Content="DHHS"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6"
                              IsChecked="{Binding ReleaseDhhsCompliant, Mode=OneWay}"
                              Command="{Binding ToggleFormCommand}"
                              CommandParameter="{x:Static sati:FormType.Release_DHHS}" />
                    <CheckBox Grid.Row="2"
                              Grid.Column="4"
                              Content="Agency"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6"
                              IsChecked="{Binding ReleaseAgencyCompliant, Mode=OneWay}"
                              Command="{Binding ToggleFormCommand}"
                              CommandParameter="{x:Static sati:FormType.Release_Agency}" />
                    <CheckBox Grid.Row="3"
                              Grid.Column="4"
                              Content="Medical"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6"
                              IsChecked="{Binding ReleaseMedicalCompliant, Mode=OneWay}"
                              Command="{Binding ToggleFormCommand}"
                              CommandParameter="{x:Static sati:FormType.Release_Medical}" />
                </Grid>

                <Separator Margin="0,12,0,12" />

                <!-- Monthly productivity -->
                <TextBlock Text="MONTHLY PRODUCTIVITY"
                           Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PENDING"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding PendingUnits}"
                                   FontSize="20"
                                   Foreground="#3D2B1F" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="LOGGED"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding LoggedUnits}"
                                   FontSize="20"
                                   Foreground="#3D2B1F" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ABANDONED"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding AbandonedUnits}"
                                   FontSize="20"
                                   Foreground="#3D2B1F" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="DAILY AVG"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding DailyAverageUnits, StringFormat={}{0:F1}}"
                                   FontSize="20"
                                   Foreground="#3D2B1F" />
                    </StackPanel>
                </Grid>

                <TextBlock Style="{StaticResource LabelStyle}">
                    <Run Text="{Binding LoggedUnits, Mode=OneWay}" />
                    <Run Text=" / " />
                    <Run Text="{Binding Threshold, Mode=OneWay}" />
                    <Run Text=" units" />
                </TextBlock>
                <ProgressBar Minimum="0"
                             Maximum="{Binding SafeThreshold, TargetNullValue=1, FallbackValue=1}"
                             Value="{Binding LoggedUnits, Mode=OneWay}"
                             Height="10"
                             Margin="0,4,0,8"
                             Foreground="#C87941"
                             Background="#E8D0B8"
                             BorderThickness="0" />

                <TextBlock Text="ESTIMATED INCENTIVE"
                           Style="{StaticResource LabelStyle}" />
                <TextBlock Text="{Binding EstimatedIncentive, StringFormat=C}"
                           FontSize="20"
                           Foreground="#3D2B1F" />
            </StackPanel>
        </Border>

        <!-- ═══ COL 4 ROW 0: UPCOMING TASKS ═══ -->
        <Border Grid.Column="4"
                Grid.Row="0"
                Grid.RowSpan="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Tab buttons: Upcoming | Overdue -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">

                        <Button Command="{Binding SelectUpcomingTabCommand}"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border BorderThickness="0,0,0,2"
                                            Padding="0,0,12,4"
                                            Background="Transparent">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush"
                                                        Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowOverdue}"
                                                                 Value="False">
                                                        <Setter Property="BorderBrush"
                                                                Value="#C87941" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="UPCOMING"
                                                   FontSize="11"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground"
                                                            Value="#9C7A5C" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowOverdue}"
                                                                     Value="False">
                                                            <Setter Property="Foreground"
                                                                    Value="#3D2B1F" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Command="{Binding SelectOverdueTabCommand}"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border BorderThickness="0,0,0,2"
                                            Padding="0,0,0,4"
                                            Background="Transparent">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush"
                                                        Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowOverdue}"
                                                                 Value="True">
                                                        <Setter Property="BorderBrush"
                                                                Value="#C0392B" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="OVERDUE"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,5,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground"
                                                                Value="#9C7A5C" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowOverdue}"
                                                                         Value="True">
                                                                <Setter Property="Foreground"
                                                                        Value="#3D2B1F" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Border Background="#C0392B"
                                                    CornerRadius="8"
                                                    Padding="5,1"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding HasOverdueEvents,
                                                        Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding OverdueCount}"
                                                           FontSize="10"
                                                           Foreground="White"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>

                    <!-- Sort toggles — abbreviated to save space -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                        <RadioButton GroupName="SortEventsBy"
                                     Content="Date"
                                     IsChecked="{Binding SortByDate, Mode=TwoWay}"
                                     Foreground="#9C7A5C"
                                     FontSize="10"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center" />
                        <RadioButton GroupName="SortEventsBy"
                                     Content="Type"
                                     IsChecked="{Binding SortByDate,
                                         Converter={StaticResource InverseBoolConverter},
                                         Mode=TwoWay}"
                                     Foreground="#9C7A5C"
                                     FontSize="10"
                                     VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <Separator Grid.Row="1" />

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding AllEvents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2"
                                        Padding="6,4"
                                        CornerRadius="3"
                                        BorderThickness="3,0,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <!-- Default: open form deadline (amber) -->
                                            <Setter Property="BorderBrush"
                                                    Value="#C87941" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Kind}"
                                                             Value="{x:Static sati:UpcomingEventKind.LateReview}">
                                                    <Setter Property="BorderBrush"
                                                            Value="#C0392B" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}"
                                                             Value="{x:Static sati:UpcomingEventKind.ScheduledVisit}">
                                                    <Setter Property="BorderBrush"
                                                            Value="#6B8E6B" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}"
                                                             Value="{x:Static sati:UpcomingEventKind.ScheduledContact}">
                                                    <Setter Property="BorderBrush"
                                                            Value="#9C7A5C" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#3D2B1F"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Date, StringFormat={}{0:MMM d}}"
                                                   FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground"
                                                            Value="#9C7A5C" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Kind}"
                                                                     Value="{x:Static sati:UpcomingEventKind.LateReview}">
                                                            <Setter Property="Foreground"
                                                                    Value="#C0392B" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ COL 4 ROWS 1-2: EFFECTIVE DATES ═══ -->
        <Border Grid.Column="4"
                Grid.Row="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="EFFECTIVE DATES"
                           Style="{StaticResource SectionHeader}" />
                <Separator Grid.Row="1" />

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding EffectiveDateGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        CornerRadius="4"
                                        Padding="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrent}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="#EDD9C0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#9C7A5C"
                                                   Margin="0,0,0,4" />
                                        <ItemsControl ItemsSource="{Binding ClientNames}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               FontSize="12"
                                                               Foreground="#3D2B1F"
                                                               Margin="0,2" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Compliance dialog overlay -->
        <Grid Background="#80000000"
              Grid.RowSpan="3"
              Grid.ColumnSpan="5"
              Visibility="{Binding IsComplianceDialogVisible,
                  Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#FDF6EC"
                    BorderBrush="#D9AEAE"
                    BorderThickness="1"
                    CornerRadius="6"
                    Width="460"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>

                    <TextBlock Text="CLIENT NOT BILLING COMPLIANT"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#7A3B3B"
                               Margin="0,0,0,8" />

                    <TextBlock TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#3D2B1F"
                               Margin="0,0,0,12">
                        <Run Text="{Binding SelectedPerson.FullName, FallbackValue='This client', Mode=OneWay}" />
                        <Run Text="does not currently meet billing compliance requirements. You may hold this note in your queue until compliance is resolved, or send it to your supervisor with a written justification." />
                    </TextBlock>

                    <Border Background="#FFF0E8"
                            BorderBrush="#D9AEAE"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,8"
                            Margin="0,0,0,12">
                        <ItemsControl ItemsSource="{Binding ComplianceFailureReasons}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontSize="12"
                                               Foreground="#7A3B3B"
                                               Margin="0,2"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <TextBlock Text="JUSTIFICATION"
                               FontSize="10"
                               Foreground="#9C7A5C"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Required if sending to supervisor. Ignored if holding."
                               FontSize="10"
                               Foreground="#9C7A5C"
                               Margin="0,0,0,6" />
                    <TextBox Text="{Binding PendingJustification, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="90"
                             Padding="8"
                             FontSize="12"
                             Background="White"
                             BorderBrush="#D9AEAE"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,16" />

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Padding="14,6"
                                FontSize="12"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="#9C7A5C"
                                Foreground="#FDF6EC"
                                Margin="0,0,6,0"
                                Command="{Binding CancelComplianceDialogCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Hold for Now"
                                Padding="14,6"
                                FontSize="12"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="#C87941"
                                Foreground="#FDF6EC"
                                Margin="0,0,6,0"
                                Command="{Binding HoldForComplianceCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Send to Supervisor"
                                Padding="14,6"
                                FontSize="12"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="#7A3B3B"
                                Foreground="#FDF6EC"
                                Command="{Binding SendToSupervisorCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>