<UserControl x:Class="Sati.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sati="clr-namespace:Sati"
             Background="#FDF6EC"
             TextElement.FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ================================================================ -->
        <!-- SIDEBAR — user list                                               -->
        <!-- ================================================================ -->
        <Border Grid.Column="0"
                Background="#F5EAD8"
                BorderBrush="#E8D0B8"
                BorderThickness="0,0,1,0">
            <StackPanel>
                <TextBlock Text="ALL USERS"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#9C7A5C"
                           Margin="12,14,12,10" />

                <ItemsControl ItemsSource="{Binding Users}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Cursor="Hand"
                                    Padding="0">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectUserCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}" />
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="Transparent" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter Property="Background"
                                                        Value="#EDD9C0" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Margin="12,6">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="12"
                                               Foreground="#3D2B1F" />
                                    <TextBlock Text="{Binding Role}"
                                               FontSize="10"
                                               Foreground="#9C7A5C" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ================================================================ -->
        <!-- MAIN CONTENT — edit panel                                         -->
        <!-- ================================================================ -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24,20">
            <StackPanel>

                <!-- Empty state -->
                <TextBlock Text="Select a user to edit"
                           FontSize="14"
                           Foreground="#9C7A5C"
                           Margin="0,0,0,16"
                           Visibility="{Binding HasSelectedUser,
                               Converter={StaticResource BoolToVisibilityConverter},
                               ConverterParameter=Inverse}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility"
                                    Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedUser}"
                                             Value="False">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Edit panel -->
                <StackPanel Visibility="{Binding HasSelectedUser,
                                Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock Text="{Binding SelectedUser.DisplayName}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#3D2B1F"
                               Margin="0,0,0,4" />
                    <TextBlock Text="{Binding SelectedUser.Username}"
                               FontSize="12"
                               Foreground="#9C7A5C"
                               Margin="0,0,0,20" />

                    <!-- Role -->
                    <TextBlock Text="ROLE"
                               Style="{StaticResource LabelStyle}" />
                    <ComboBox ItemsSource="{Binding Roles}"
                              SelectedItem="{Binding SelectedRole}"
                              Margin="0,0,0,16" />

                    <!-- Supervisor -->
                    <TextBlock Text="SUPERVISOR"
                               Style="{StaticResource LabelStyle}" />
                    <ComboBox ItemsSource="{Binding Supervisors}"
                              SelectedItem="{Binding SelectedSupervisor}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,0,24" />

                    <!-- Save button -->
                    <Button Content="Save Changes"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveChangesCommand}"
                            Margin="0,0,0,12" />

                    <!-- Password reset -->
                    <Border Background="#F0E4D0"
                            BorderBrush="#E8D0B8"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="PASSWORD RESET"
                                       Style="{StaticResource LabelStyle}"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="Resets the user's password to 'defaultpassword'. The user should change it on next login."
                                       FontSize="12"
                                       Foreground="#9C7A5C"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />
                            <Button Content="Reset Password"
                                    Style="{StaticResource SmallButton}"
                                    Command="{Binding ResetPasswordCommand}"
                                    HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <!-- Status message -->
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12"
                               Foreground="#3A6B35"
                               Visibility="{Binding StatusMessage,
                                   Converter={StaticResource BoolToVisibilityConverter}}" />

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>