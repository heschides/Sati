<UserControl x:Class="Sati.Views.OverdueItemsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FDF6EC">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,32">

            <!-- ── Filters ── -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Case Manager"
                           VerticalAlignment="Center"
                           FontFamily="Inter"
                           FontSize="12"
                           Foreground="#8A7A6A"
                           Margin="0,0,8,0" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding CaseManagerNames}"
                          SelectedItem="{Binding SelectedCaseManagerName}"
                          FontFamily="Inter"
                          FontSize="13" />
                <TextBlock Grid.Column="3"
                           Text="Upcoming window"
                           VerticalAlignment="Center"
                           FontFamily="Inter"
                           FontSize="12"
                           Foreground="#8A7A6A"
                           Margin="0,0,8,0" />
                <ComboBox Grid.Column="4"
                          SelectedValue="{Binding UpcomingWindowDays}"
                          FontFamily="Inter"
                          FontSize="13">
                    <ComboBoxItem Content="30 days"
                                  Tag="30" />
                    <ComboBoxItem Content="60 days"
                                  Tag="60" />
                    <ComboBoxItem Content="90 days"
                                  Tag="90" />
                </ComboBox>
            </Grid>

            <!-- ── Overdue items ── -->
            <TextBlock FontFamily="Inter"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#A6607A"
                       Margin="0,0,0,8">
                <Run Text="OVERDUE" />
                <Run Text=" " />
                <Run Text="{Binding OverdueRows.Count, Mode=OneWay, StringFormat=({0})}" /></TextBlock>
            <Border Background="White"
                    BorderBrush="#EDD9C0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="0,0,0,24">
                <ItemsControl ItemsSource="{Binding OverdueRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EDD9C0"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding ClientName}"
                                               FontFamily="Inter"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#3D2B1F" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontFamily="Inter"
                                               FontSize="12"
                                               Foreground="#5A4A3A"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Date, StringFormat='Due {0:MMM d, yyyy}'}"
                                               FontFamily="Inter"
                                               FontSize="12"
                                               Foreground="#8A7A6A"
                                               VerticalAlignment="Center" />
                                    <Border Grid.Column="3"
                                            Background="#EDD4D4"
                                            CornerRadius="3"
                                            Padding="6,2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                        <TextBlock FontFamily="Inter"
                                                   FontSize="11"
                                                   Foreground="#7A3040">
                                            <Run Text="{Binding DaysOverdue}" />
                                            <Run Text="d overdue" />
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- ── Upcoming items ── -->
            <TextBlock FontFamily="Inter"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#5B7FA6"
                       Margin="0,0,0,8">
                <Run Text="UPCOMING" />
                <Run Text=" " />
                <Run Text="{Binding UpcomingRows.Count, Mode=OneWay, StringFormat=({0})}" /></TextBlock>
            <Border Background="White"
                    BorderBrush="#EDD9C0"
                    BorderThickness="1"
                    CornerRadius="6">
                <ItemsControl ItemsSource="{Binding UpcomingRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EDD9C0"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding ClientName}"
                                               FontFamily="Inter"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#3D2B1F" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontFamily="Inter"
                                               FontSize="12"
                                               Foreground="#5A4A3A"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Date, StringFormat='Due {0:MMM d, yyyy}'}"
                                               FontFamily="Inter"
                                               FontSize="12"
                                               Foreground="#8A7A6A"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Kind}"
                                               FontFamily="Inter"
                                               FontSize="11"
                                               Foreground="#5B7FA6"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>