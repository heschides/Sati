<Window x:Class="Sati.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Sati.Views"
        Icon="/Images/sati.ico"
        Title="Sati"
        MinWidth="900"
        MinHeight="600"
        Background="#FDF6EC"
        FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="300"
                              MinWidth="250" />
        </Grid.ColumnDefinitions>

        <!-- ================================================================ -->
        <!-- NAVIGATION BAR                                                   -->
        <!-- ================================================================ -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Background="#F5E6D0"
                BorderBrush="#E8D0B8"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Tab navigation — left side -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    <Border Cursor="Hand"
                            CornerRadius="4"
                            Padding="10,4"
                            Margin="0,0,4,0">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding NavigateToCaseManagementCommand}" />
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNotesActive}"
                                                 Value="True">
                                        <Setter Property="Background"
                                                Value="#3D2B1F" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#EDD9C0" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Case Management"
                                   FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="#9C7A5C" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNotesActive}"
                                                     Value="True">
                                            <Setter Property="Foreground"
                                                    Value="#FDF6EC" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <Border Cursor="Hand"
                            CornerRadius="4"
                            Padding="10,4"
                            Margin="0,0,4,0"
                            Visibility="{Binding IsSupervisionAvailable,
                                Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding NavigateToSupervisorDashboardCommand}" />
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSupervisorActive}"
                                                 Value="True">
                                        <Setter Property="Background"
                                                Value="#3D2B1F" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#EDD9C0" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Supervisor"
                                   FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="#9C7A5C" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSupervisorActive}"
                                                     Value="True">
                                            <Setter Property="Foreground"
                                                    Value="#FDF6EC" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <Border Cursor="Hand"
                            CornerRadius="4"
                            Padding="10,4"
                            Margin="0,0,4,0"
                            Visibility="{Binding IsBillingAvailable,
            Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding NavigateToBillingCommand}" />
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBillingActive}"
                                                 Value="True">
                                        <Setter Property="Background"
                                                Value="#3D2B1F" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#EDD9C0" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Billing"
                                   FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="#9C7A5C" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBillingActive}"
                                                     Value="True">
                                            <Setter Property="Foreground"
                                                    Value="#FDF6EC" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    

                    <Border Cursor="Hand"
                            CornerRadius="4"
                            Padding="10,4"
                            Margin="0,0,4,0">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding NavigateToGuidanceCommand}" />
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGuidanceActive}"
                                                 Value="True">
                                        <Setter Property="Background"
                                                Value="#3D2B1F" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#EDD9C0" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Guidance"
                                   FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="#9C7A5C" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGuidanceActive}"
                                                     Value="True">
                                            <Setter Property="Foreground"
                                                    Value="#FDF6EC" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <Border Cursor="Hand"
                            CornerRadius="4"
                            Padding="10,4"
                            Margin="0,0,4,0">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding NavigateToHelpersCommand}" />
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHelpersActive}"
                                                 Value="True">
                                        <Setter Property="Background"
                                                Value="#3D2B1F" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#EDD9C0" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Helpers"
                                   FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="#9C7A5C" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHelpersActive}"
                                                     Value="True">
                                            <Setter Property="Foreground"
                                                    Value="#FDF6EC" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                </StackPanel>

                <!-- User info — right side -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- Settings -->
                    <Button Grid.Column="0"
                            Style="{StaticResource SmallButton}"
                            ToolTip="Settings"
                            Width="28"
                            Command="{Binding OpenSettingsWindowCommand}"
                            Background="Transparent"
                            Padding="0">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE713;"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Button>

                    <!-- User greeting -->
                    <Border Cursor="Hand"
                            CornerRadius="4"
                            Padding="8,4"
                            VerticalAlignment="Center"
                            Background="{Binding AvatarBrush}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding RequestSwitchUserCommand}" />
                        </Border.InputBindings>
                        <TextBlock Text="{Binding UserGreeting}"
                                   FontSize="12"
                                   Foreground="#FDF6EC"
                                   VerticalAlignment="Center" />
                    </Border>

                </StackPanel>

            </Grid>
        </Border>

        <!-- ================================================================ -->
        <!-- MAIN CONTENT AREA                                                -->
        <!-- ================================================================ -->
        <ContentControl Grid.Row="1"
                        Grid.Column="0"
                        Content="{Binding CurrentViewModel}" />

        <!-- GridSplitter -->
        <GridSplitter Grid.Row="1"
                      Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      Background="#E8D0B8" />

        <!-- Scratchpad panel -->
        <Border Grid.Row="1"
                Grid.Column="2"
                BorderBrush="#E8D0B8"
                Margin="8,12,12,20"
                BorderThickness="0"
                MinWidth="250"
                Visibility="{Binding IsScratchpadVisible,
                             Converter={StaticResource BoolToVisibilityConverter}}">
            <views:ScratchpadView DataContext="{Binding Scratchpad}" />
        </Border>

    </Grid>
</Window>