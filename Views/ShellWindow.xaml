<Window x:Class="Sati.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Sati.Views"
        Title="Sati"
        MinWidth="900"
        MinHeight="600"
        Background="#FDF6EC"
        FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="300"
                              MinWidth="250" />
        </Grid.ColumnDefinitions>

        <!-- Navigation bar -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Background="#F5E6D0"
                BorderBrush="#E8D0B8"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">

                <Button Command="{Binding NavigateToNotesCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,4,0"
                        Padding="10,4">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground"
                                    Value="#9C7A5C" />
                            <Setter Property="FontSize"
                                    Value="13" />
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNotesActive}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="#C87941" />
                                    <Setter Property="Foreground"
                                            Value="#FDF6EC" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="#EDD9C0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="Notes"
                               FontSize="13" />
                </Button>

                <Button Command="{Binding NavigateToSupervisorDashboardCommand}"
                        Visibility="{Binding IsSupervisionAvailable,
                    Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,4,0"
                        Padding="10,4">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground"
                                    Value="#9C7A5C" />
                            <Setter Property="FontSize"
                                    Value="13" />
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSupervisorActive}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="#C87941" />
                                    <Setter Property="Foreground"
                                            Value="#FDF6EC" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="#EDD9C0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="Supervisor"
                               FontSize="13" />
                </Button>

                <Button Command="{Binding NavigateToGuidanceCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,4,0"
                        Padding="10,4">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground"
                                    Value="#9C7A5C" />
                            <Setter Property="FontSize"
                                    Value="13" />
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGuidanceActive}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="#C87941" />
                                    <Setter Property="Foreground"
                                            Value="#FDF6EC" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="#EDD9C0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="Guidance"
                               FontSize="13" />
                </Button>

                <Button Command="{Binding NavigateToHelpersCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,4,0"
                        Padding="10,4">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground"
                                    Value="#9C7A5C" />
                            <Setter Property="FontSize"
                                    Value="13" />
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHelpersActive}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="#C87941" />
                                    <Setter Property="Foreground"
                                            Value="#FDF6EC" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="#EDD9C0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="Helpers"
                               FontSize="13" />
                </Button>

            </StackPanel>
        </Border>

        <!-- Main content area -->
        <ContentControl Grid.Row="1"
                        Grid.Column="0"
                        Content="{Binding CurrentViewModel}" />

        <!-- GridSplitter -->
        <GridSplitter Grid.Row="1"
                      Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      Background="#E8D0B8" />

        <!-- Scratchpad panel -->
        <Border Grid.Row="1"
                Grid.Column="2"
                BorderBrush="#E8D0B8"
                Margin="8,12,12,20"
                BorderThickness="0"
                MinWidth="250"
                Visibility="{Binding IsScratchpadVisible,
                             Converter={StaticResource BoolToVisibilityConverter}}">
            <views:ScratchpadView DataContext="{Binding Scratchpad}" />
        </Border>
    </Grid>
</Window>