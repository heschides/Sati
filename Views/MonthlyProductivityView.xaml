<UserControl x:Class="Sati.Views.MonthlyProductivityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             Background="#FDF6EC">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,32">

            <!-- ── Team status totals ── -->
            <TextBlock Text="TEAM TOTALS THIS MONTH"
                       FontFamily="Inter"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#8A7A6A"
                       Margin="0,0,0,8" />
            <UniformGrid Columns="6"
                         Margin="0,0,0,24">
                <Border Margin="0,0,4,0"
                        Background="White"
                        BorderBrush="#EDD9C0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="{Binding TeamLogged}"
                                   FontFamily="Inter"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#5A8A5A" />
                        <TextBlock Text="Logged"
                                   FontFamily="Inter"
                                   FontSize="11"
                                   Foreground="#8A7A6A" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0"
                        Background="White"
                        BorderBrush="#EDD9C0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="{Binding TeamScheduled}"
                                   FontFamily="Inter"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#5B7FA6" />
                        <TextBlock Text="Scheduled"
                                   FontFamily="Inter"
                                   FontSize="11"
                                   Foreground="#8A7A6A" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0"
                        Background="White"
                        BorderBrush="#EDD9C0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="{Binding TeamPending}"
                                   FontFamily="Inter"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#C87941" />
                        <TextBlock Text="Pending"
                                   FontFamily="Inter"
                                   FontSize="11"
                                   Foreground="#8A7A6A" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0"
                        Background="White"
                        BorderBrush="#EDD9C0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="{Binding TeamDelayed}"
                                   FontFamily="Inter"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#D4A060" />
                        <TextBlock Text="Delayed"
                                   FontFamily="Inter"
                                   FontSize="11"
                                   Foreground="#8A7A6A" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0"
                        Background="White"
                        BorderBrush="#EDD9C0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="{Binding TeamCancelled}"
                                   FontFamily="Inter"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#8A7A6A" />
                        <TextBlock Text="Cancelled"
                                   FontFamily="Inter"
                                   FontSize="11"
                                   Foreground="#8A7A6A" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0,0,0"
                        Background="White"
                        BorderBrush="#EDD9C0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="{Binding TeamAbandoned}"
                                   FontFamily="Inter"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#A6607A" />
                        <TextBlock Text="Abandoned"
                                   FontFamily="Inter"
                                   FontSize="11"
                                   Foreground="#8A7A6A" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Per-CM breakdown table ── -->
            <TextBlock Text="BY CASE MANAGER"
                       FontFamily="Inter"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#8A7A6A"
                       Margin="0,0,0,8" />
            <DataGrid ItemsSource="{Binding CaseManagers}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionUnit="FullRow"
                      SelectionMode="Single"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#FAF0E4"
                      HorizontalGridLinesBrush="#EDD9C0"
                      Margin="0,0,0,28">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"
                                Value="Transparent" />
                        <Setter Property="Foreground"
                                Value="#8A7A6A" />
                        <Setter Property="FontFamily"
                                Value="Inter" />
                        <Setter Property="FontSize"
                                Value="11" />
                        <Setter Property="FontWeight"
                                Value="SemiBold" />
                        <Setter Property="Padding"
                                Value="8,8" />
                        <Setter Property="BorderThickness"
                                Value="0,0,0,1" />
                        <Setter Property="BorderBrush"
                                Value="#EDD9C0" />
                        <Setter Property="SeparatorVisibility"
                                Value="Collapsed" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness"
                                Value="0" />
                        <Setter Property="Padding"
                                Value="8,6" />
                        <Setter Property="Foreground"
                                Value="#3D2B1F" />
                        <Setter Property="FontFamily"
                                Value="Inter" />
                        <Setter Property="Background"
                                Value="Transparent" />
                        <Setter Property="FocusVisualStyle"
                                Value="{x:Null}" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#EDD9C0" />
                                <Setter Property="Foreground"
                                        Value="#3D2B1F" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="BorderThickness"
                                Value="0" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#EDD9C0" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding DisplayName}"
                                        Width="*" />
                    <DataGridTextColumn Header="Logged"
                                        Binding="{Binding LoggedCount}"
                                        Width="70" />
                    <DataGridTextColumn Header="Sched."
                                        Binding="{Binding ScheduledCount}"
                                        Width="60" />
                    <DataGridTextColumn Header="Pending"
                                        Binding="{Binding PendingCount}"
                                        Width="70" />
                    <DataGridTextColumn Header="Delayed"
                                        Binding="{Binding DelayedCount}"
                                        Width="70" />
                    <DataGridTextColumn Header="Cancelled"
                                        Binding="{Binding CancelledCount}"
                                        Width="80" />
                    <DataGridTextColumn Header="Abandoned"
                                        Binding="{Binding AbandonedCount}"
                                        Width="80" />
                    <DataGridTemplateColumn Header="Progress"
                                            Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                             Maximum="100"
                                             Height="8"
                                             Margin="8,6"
                                             BorderThickness="0">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar">
                                            <Setter Property="Foreground"
                                                    Value="#C87941" />
                                            <Setter Property="Background"
                                                    Value="#EDD9C0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusLevel}"
                                                             Value="Ok">
                                                    <Setter Property="Foreground"
                                                            Value="#5A8A5A" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusLevel}"
                                                             Value="Danger">
                                                    <Setter Property="Foreground"
                                                            Value="#A6607A" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="%"
                                        Binding="{Binding ProgressPercent, StringFormat={}{0:0}%}"
                                        Width="50" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── Stacked status chart ── -->
            <TextBlock Text="NOTE STATUS BY CASE MANAGER"
                       FontFamily="Inter"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#8A7A6A"
                       Margin="0,0,0,8" />
            <Border Background="White"
                    BorderBrush="#EDD9C0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <oxy:PlotView Name="StatusChart"
                    Model="{Binding StatusChartModel}"
                              Height="340"
                              Background="Transparent" />
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>