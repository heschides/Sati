<UserControl x:Class="Sati.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:children="clr-namespace:Sati.ViewModels.Children"
             Background="#FDF6EC"
             TextElement.FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="0,0,1,0"
                Padding="16">
            <StackPanel>

                <!-- Selected date header -->
                <TextBlock FontSize="14"
                           FontWeight="Medium"
                           Foreground="#3D2B1F"
                           Margin="0,0,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text"
                                    Value="Select a date" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedDay}"
                                             Value="{x:Null}">
                                    <Setter Property="Text"
                                            Value="Select a date" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Selected day date display -->
                <TextBlock Text="{Binding SelectedDay.Date, StringFormat='{}{0:MMMM d, yyyy}'}"
                           FontSize="14"
                           FontWeight="Medium"
                           Foreground="#3D2B1F"
                           Margin="0,0,0,12"
                           Visibility="{Binding SelectedDay,
                               Converter={StaticResource NullToVisibilityConverter}}" />

                <!-- Notes section -->
                <TextBlock Text="NOTES"
                           FontSize="10"
                           Foreground="#9C7A5C"
                           Margin="0,0,0,6" />

                <ItemsControl ItemsSource="{Binding SelectedDayNotes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,6">
                                <TextBlock Text="{Binding Person.FullName}"
                                           FontSize="11"
                                           FontWeight="Medium"
                                           Foreground="#3D2B1F" />
                                <TextBlock Text="{Binding Narrative}"
                                           FontSize="11"
                                           Foreground="#9C7A5C"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="11"
                                           Foreground="#9C7A5C">
                                    <Run Text="{Binding Minutes}" /><Run Text=" min · " /><Run Text="{Binding Units}" /><Run Text=" units" />
                                </TextBlock>
                                <Separator Margin="0,4,0,0"
                                           Background="#E8D0B8" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="No notes on this date."
                           FontSize="11"
                           FontStyle="Italic"
                           Foreground="#9C7A5C"
                           Margin="0,0,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility"
                                    Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedDay.HasNotes}"
                                             Value="False">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Separator Background="#E8D0B8"
                           Margin="0,8,0,12" />

                <!-- Exempt days for selected month -->
                <TextBlock FontSize="10"
                           Foreground="#9C7A5C"
                           Margin="0,0,0,6">
                    <Run Text="EXEMPT — " /><Run Text="{Binding SelectedMonthName, Mode=OneWay}" />
                </TextBlock>

                <ItemsControl ItemsSource="{Binding ExemptDaysForSelectedMonth}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Date, StringFormat={}{0:MMM d}}"
                                       FontSize="11"
                                       Foreground="#9C7A5C"
                                       TextDecorations="Strikethrough"
                                       Margin="0,0,0,4" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="None this month."
                           FontSize="11"
                           FontStyle="Italic"
                           Foreground="#9C7A5C">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility"
                                    Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ExemptDaysForSelectedMonth.Count}"
                                             Value="0">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>
        </Border>

        <!-- ═══ CALENDAR GRID ═══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Year navigation -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="16,12,16,8">
                <Button Content="&#8249;"
                        Command="{Binding PreviousYearCommand}"
                        Width="24"
                        Height="24"
                        Background="Transparent"
                        BorderBrush="#E8D0B8"
                        BorderThickness="1"
                        Foreground="#9C7A5C"
                        FontSize="16"
                        Cursor="Hand" />
                <TextBlock Text="{Binding CurrentYear}"
                           FontSize="13"
                           FontWeight="Medium"
                           Foreground="#3D2B1F"
                           VerticalAlignment="Center"
                           Margin="10,0" />
                <Button Content="&#8250;"
                        Command="{Binding NextYearCommand}"
                        Width="24"
                        Height="24"
                        Background="Transparent"
                        BorderBrush="#E8D0B8"
                        BorderThickness="1"
                        Foreground="#9C7A5C"
                        FontSize="16"
                        Cursor="Hand" />
            </StackPanel>

            <!-- 12-month grid -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,0,16,16">
                <ItemsControl ItemsSource="{Binding Months}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type children:CalendarMonth}">
                            <Border Margin="4"
                                    Background="White"
                                    BorderBrush="#E8D0B8"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    VerticalAlignment="Top">
                                <!-- Month name -->
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               Foreground="#9C7A5C"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,4" />

                                    <!-- Day-of-week headers -->
                                    <UniformGrid Columns="7"
                                                 Margin="0,0,0,2">
                                        <TextBlock Text="S"
                                                   FontSize="16"
                                                   Foreground="#C0A882"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="M"
                                                   FontSize="16"
                                                   Foreground="#C0A882"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="T"
                                                   FontSize="16"
                                                   Foreground="#C0A882"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="W"
                                                   FontSize="16"
                                                   Foreground="#C0A882"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="T"
                                                   FontSize="16"
                                                   Foreground="#C0A882"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="F"
                                                   FontSize="16"
                                                   Foreground="#C0A882"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="S"
                                                   FontSize="16"
                                                   Foreground="#C0A882"
                                                   HorizontalAlignment="Center" />
                                    </UniformGrid>

                                    <!-- Day cells -->
                                    <ItemsControl ItemsSource="{Binding Cells}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="7" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DataTemplate.Resources>
                                                    <Style x:Key="DayBorder"
                                                           TargetType="Border">
                                                        <Setter Property="CornerRadius"
                                                                Value="2" />
                                                        <Setter Property="Margin"
                                                                Value="1" />
                                                        <Setter Property="Cursor"
                                                                Value="Hand" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsToday}"
                                                                         Value="True">
                                                                <Setter Property="Background"
                                                                        Value="#C87941" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataTemplate.Resources>

                                                <!-- Null cell — empty slot for grid alignment -->
                                                <Grid>
                                                    <!-- Empty slot -->
                                                    <Border Visibility="{Binding Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=inverse}" />

                                                    <!-- Day cell -->
                                                    <Border Style="{StaticResource DayBorder}"
                                                            Visibility="{Binding Converter={StaticResource NullToVisibilityConverter}}">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.SelectDayCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                          CommandParameter="{Binding}" />
                                                            <MouseBinding MouseAction="RightClick"
                                                                          Command="{Binding DataContext.ToggleExemptCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                          CommandParameter="{Binding}" />
                                                        </Border.InputBindings>

                                                        <TextBlock HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="14">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text"
                                                                            Value="{Binding Date.Day}" />
                                                                    <Setter Property="Foreground"
                                                                            Value="#3D2B1F" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsWeekend}"
                                                                                     Value="True">
                                                                            <Setter Property="Foreground"
                                                                                    Value="#C0A882" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsExempt}"
                                                                                     Value="True">
                                                                            <Setter Property="Foreground"
                                                                                    Value="#C0A882" />
                                                                            <Setter Property="TextDecorations"
                                                                                    Value="Strikethrough" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsToday}"
                                                                                     Value="True">
                                                                            <Setter Property="Foreground"
                                                                                    Value="White" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>