<UserControl x:Class="Sati.Views.Billing.BillingSubmissionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FDF6EC"
             TextElement.FontFamily="{StaticResource AppFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="837P CLAIM SUBMISSION"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="#9C7A5C"
                   Margin="0,0,0,16" />

        <!-- Billing period selector -->
        <StackPanel Grid.Row="1"
                    Margin="0,0,0,16">
            <TextBlock Text="BILLING PERIOD"
                       Style="{StaticResource LabelStyle}" />
            <ComboBox ItemsSource="{Binding BillingPeriods}"
                      SelectedItem="{Binding SelectedPeriod}"
                      Width="300"
                      HorizontalAlignment="Left">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding Year, Mode=OneWay}" />
                            <Run Text=" — Month " />
                            <Run Text="{Binding Month, Mode=OneWay}" />
                            <Run Text=" (" />
                            <Run Text="{Binding Lines.Count, Mode=OneWay}" />
                            <Run Text=" claims)" />
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <!-- Test mode toggle -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <CheckBox IsChecked="{Binding IsTestMode}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0" />
            <TextBlock Text="Test mode (OATEST in filename — safe to upload to Office Ally)"
                       FontSize="12"
                       Foreground="#3D2B1F"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Generate button -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <Button Content="Generate 837P File"
                    Style="{StaticResource PrimaryButton}"
                    Width="180"
                    Command="{Binding GenerateEdiCommand}"
                    IsEnabled="{Binding HasSelectedPeriod}"
                    Margin="0,0,12,0" />
            <Button Content="Open Output Folder"
                    Style="{StaticResource SmallButton}"
                    Width="150"
                    Command="{Binding OpenOutputFolderCommand}"
                    IsEnabled="{Binding HasGeneratedFile}"
                    VerticalAlignment="Center" />
        </StackPanel>

        <!-- Status message -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   FontSize="12"
                   Foreground="#3D2B1F"
                   TextWrapping="Wrap" />

    </Grid>
</UserControl>