<Window x:Class="Sati.Views.UserMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message to User"
        Height="Auto"
        Width="380"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FDF6EC"
        BorderBrush="#E8D0B8"
        BorderThickness="1">

    <StackPanel Margin="24">
        <TextBlock Text="BEFORE YOU SUBMIT"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="#9C7A5C"
                   Margin="0,0,0,8" />
        <TextBlock Text="{Binding ErrorMessage}"
                   FontSize="13"
                   Foreground="#3D2B1F"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   Margin="0,0,0,20" />
        <Button Content="Got it"
                HorizontalAlignment="Right"
                Padding="20,6"
                FontSize="13"
                Background="#C87941"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="OkButton_Click" />
    </StackPanel>
</Window>