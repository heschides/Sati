<Window x:Class="Sati.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sati"
        mc:Ignorable="d"
        Title="Sati"
        Background="#FDF6EC">

    <Window.Resources>

        <Style x:Key="LabelStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="Margin"
                    Value="0,0,0,4" />
        </Style>

        <Style x:Key="SectionHeader"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding"
                    Value="8,4" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding"
                    Value="6,4" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background"
                    Value="#E8D0B8" />
            <Setter Property="Margin"
                    Value="0,4,0,12" />
        </Style>

        <Style x:Key="PrimaryButton"
               TargetType="Button">
            <Setter Property="Height"
                    Value="36" />
            <Setter Property="Background"
                    Value="#C87941" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#A85E28" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#8A4D20" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButton"
               TargetType="Button">
            <Setter Property="Height"
                    Value="28" />
            <Setter Property="Padding"
                    Value="12,0" />
            <Setter Property="Background"
                    Value="#EDD9C0" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#D4A882" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!--
        MAIN LAYOUT: 5 columns (3 content + 2 spacers), 3 rows
        ┌─────────────┬───┬─────────────┬───┬─────────────┐
        │ Col 0       │   │ Col 2       │   │ Col 4       │
        ├─────────────┤   ├─────────────┤   ├─────────────┤
        │ Row 0       │   │ Row 0       │   │ Rows 0-1    │
        │ Client List │   │ Filter bar  │   │ Productivity│
        │ button      │   │             │   │ + Today's   │
        ├─────────────┤   ├─────────────┤   │ Work        │
        │ Rows 1-2    │   │ Row 1       │   ├─────────────┤
        │ Note entry  │   │ Notes       │   │ Row 2       │
        │ form        │   │ DataGrid    │   │ Upcoming    │
        │             │   ├─────────────┤   │ Tasks       │
        │             │   │ Row 2       │   │             │
        │             │   │ Forms       │   │             │
        │             │   │ checklist   │   │             │
        └─────────────┴───┴─────────────┴───┴─────────────┘
    -->
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ COL 0 ROW 0: CLIENT LIST BUTTON ═══ -->
        <Grid Grid.Column="0"
              Grid.Row="0"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource SmallButton}"
                    ToolTip="Settings"
                    Width="28"
                    Command="{Binding OpenSettingsWindowCommand}"
                    Background="Transparent"
                    Padding="0">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE713;"
                           FontSize="14"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
            </Button>

            <Button Grid.Column="2"
                    Content="Client List"
                    Style="{StaticResource SmallButton}"
                    Command="{Binding OpenClientListCommand}"
                    HorizontalAlignment="Stretch" />
        </Grid>

        <!-- ═══ COL 0 ROWS 1-2: NOTE ENTRY FORM ═══ -->
        <Border Grid.Column="0"
                Grid.Row="1"
                Grid.RowSpan="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="NEW NOTE"
                           Style="{StaticResource SectionHeader}" />

                <TextBlock Text="CLIENT"
                           Grid.Row="1"
                           Style="{StaticResource LabelStyle}" />
                <ComboBox Grid.Row="2"
                          ItemsSource="{Binding People}"
                          SelectedItem="{Binding SelectedPerson}"
                          DisplayMemberPath="FullName" />

                <TextBlock Text="STATUS"
                           Grid.Row="3"
                           Style="{StaticResource LabelStyle}" />
                <ComboBox Grid.Row="4"
                          ItemsSource="{Binding NoteStatusOptions}"
                          SelectedItem="{Binding Status, Mode=TwoWay}" />

                <!-- Units, Date, Narrative -->
                <Grid Grid.Row="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="UNITS"
                               Grid.Row="0"
                               Style="{StaticResource LabelStyle}" />
                    <TextBox Grid.Row="1"
                             Text="{Binding Units}" />

                    <TextBlock Text="DATE"
                               Grid.Row="2"
                               Style="{StaticResource LabelStyle}" />
                    <DatePicker Grid.Row="3"
                                SelectedDate="{Binding EventDate}" />

                    <TextBlock Text="NARRATIVE"
                               Grid.Row="4"
                               Style="{StaticResource LabelStyle}" />
                    <TextBox Grid.Row="5"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding Narrative}" />
                </Grid>

                <Button Grid.Row="6"
                        Content="Submit Note"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SubmitNoteCommand}"
                        Margin="0,10,0,0" />
            </Grid>
        </Border>

        <!-- ═══ COL 2 ROW 0: FILTER BAR ═══ -->
        <Grid Grid.Row="0"
              Grid.Column="2"
              Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="160" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="FILTER NOTES"
                       Style="{StaticResource LabelStyle}" />
            <TextBlock Grid.Row="0"
                       Grid.Column="2"
                       Text="FILTER STATUS"
                       Style="{StaticResource LabelStyle}" />

            <TextBox x:Name="SearchTextBox"
                     Grid.Row="1"
                     Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Grid.Row="1"
                      Grid.Column="2"
                      Height="{Binding ActualHeight, ElementName=SearchTextBox}"
                      ItemsSource="{Binding NoteStatusOptions}"
                      SelectedItem="{Binding FilterStatus}" />
        </Grid>

        <!-- ═══ COL 2 ROW 1: NOTES DATAGRID ═══ -->
        <Border Grid.Column="2"
                Grid.Row="1"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Margin="0,0,0,12">
            <DataGrid ItemsSource="{Binding NotesView}"
                      SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                      MouseDoubleClick="DataGrid_MouseDoubleClick"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="White"
                      AlternatingRowBackground="#FDF6EC"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F0E0D0"
                      HeadersVisibility="Column"
                      Margin="0">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Delete Note"
                                  Command="{Binding DeleteNoteCommand}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Border>

        <!-- ═══ COL 2 ROW 2: FORMS CHECKLIST ═══ -->
        <!-- ═══ COL 2 ROW 2: FORMS CHECKLIST + MONTHLY PRODUCTIVITY ═══ -->
        <Border Grid.Column="2"
                Grid.Row="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,12">
            <StackPanel>

                <!-- Forms Checklist -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="90-Day Reviews"
                               Style="{StaticResource SectionHeader}" />
                    <CheckBox Grid.Row="1"
                              Grid.Column="0"
                              Content="Quarter 1"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6" />
                    <CheckBox Grid.Row="2"
                              Grid.Column="0"
                              Content="Quarter 2"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6" />
                    <CheckBox Grid.Row="3"
                              Grid.Column="0"
                              Content="Quarter 3"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6" />
                    <CheckBox Grid.Row="4"
                              Grid.Column="0"
                              Content="Quarter 4"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="Releases"
                               Style="{StaticResource SectionHeader}" />
                    <CheckBox Grid.Row="1"
                              Grid.Column="2"
                              Content="DHHS"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6" />
                    <CheckBox Grid.Row="2"
                              Grid.Column="2"
                              Content="Agency"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6" />
                    <CheckBox Grid.Row="3"
                              Grid.Column="2"
                              Content="Doctor"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6" />
                    <CheckBox Grid.Row="4"
                              Grid.Column="2"
                              Content="Providers"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="4"
                               Text="Local Documents"
                               Style="{StaticResource SectionHeader}" />
                    <CheckBox Grid.Row="1"
                              Grid.Column="4"
                              Content="Safety Plan"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6" />
                    <CheckBox Grid.Row="2"
                              Grid.Column="4"
                              Content="Privacy Practices"
                              Foreground="#3D2B1F"
                              Margin="0,0,0,6" />
                </Grid>

                <Separator Margin="0,12,0,12" />

                <!-- Monthly Productivity -->
                <TextBlock Text="MONTHLY PRODUCTIVITY"
                           Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PENDING"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding PendingUnits}"
                                   FontSize="20"
                                   Foreground="#3D2B1F" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="LOGGED"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding LoggedUnits}"
                                   FontSize="20"
                                   Foreground="#3D2B1F" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ABANDONED"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding AbandonedUnits}"
                                   FontSize="20"
                                   Foreground="#3D2B1F" />
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Border>
        <!-- ═══ COL 4 ROWS 0-1: TODAY'S WORK (tall) ═══ -->
        <Border Grid.Column="4"
                Grid.Row="0"
                Grid.RowSpan="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="TODAY'S WORK"
                           Style="{StaticResource SectionHeader}" />
                <TextBox x:Name="TodaysWorkBox"
                         Grid.Row="1"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalAlignment="Stretch"
                         Text="TodaysWork"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="0" />
            </Grid>
        </Border>

        <!-- ═══ COL 4 ROW 2: UPCOMING TASKS ═══ -->
        <Border Grid.Column="4"
                Grid.Row="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="18,16,18,18">
                    <TextBlock Text="UPCOMING TASKS"
                               Style="{StaticResource SectionHeader}"
                               Margin="0,0,12,0" />
                    <RadioButton GroupName="SortEventsBy"
                                 Content="By Date"
                                 Foreground="#9C7A5C"
                                 FontSize="11"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center" />
                    <RadioButton GroupName="SortEventsBy"
                                 Content="By Type"
                                 Foreground="#9C7A5C"
                                 FontSize="11"
                                 VerticalAlignment="Center" />
                </StackPanel>
                <Separator />
                <ItemsControl ItemsSource="{Binding UpcomingEvents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,2">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           Foreground="#3D2B1F"
                                           FontSize="12" />
                                <TextBlock Text=" — "
                                           Foreground="#9C7A5C"
                                           FontSize="12" />
                                <TextBlock Text="{Binding DueDate, StringFormat={}{0:MMM d}}"
                                           Foreground="#9C7A5C"
                                           FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

       

    </Grid>
</Window>