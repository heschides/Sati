<Window x:Class="Sati.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:Sati.Converters"
        xmlns:local="clr-namespace:Sati"
        mc:Ignorable="d"
        Title="Sati"
        Background="#FDF6EC"
        Icon="/Images/leaf.png"
        WindowState="Maximized"
        MinWidth="900"
        MinHeight="700"
        TextElement.FontFamily="{StaticResource AppFont}">

    <Window.Resources>
        <Style x:Key="LabelStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
            <Setter Property="Margin"
                    Value="0,0,0,4" />
        </Style>

        <Style x:Key="SectionHeader"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding"
                    Value="8,4" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding"
                    Value="6,4" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#D4A882" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="Margin"
                    Value="0,0,0,10" />
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background"
                    Value="#E8D0B8" />
            <Setter Property="Margin"
                    Value="0,4,0,12" />
        </Style>

        <Style x:Key="PrimaryButton"
               TargetType="Button">
            <Setter Property="Height"
                    Value="36" />
            <Setter Property="Background"
                    Value="#C87941" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#A85E28" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#8A4D20" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButton"
               TargetType="Button">
            <Setter Property="Height"
                    Value="28" />
            <Setter Property="Padding"
                    Value="12,0" />
            <Setter Property="Background"
                    Value="#EDD9C0" />
            <Setter Property="Foreground"
                    Value="#3D2B1F" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#D4A882" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
        <converters:BoolToTileColorConverter x:Key="BoolToTileColorConverter" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />

    </Window.Resources>

    <!--
        MAIN LAYOUT: 5 columns (3 content + 2 spacers), 3 rows
        ┌─────────────┬───┬─────────────┬───┬─────────────┐
        │ Col 0       │   │ Col 2       │   │ Col 4       │
        ├─────────────┤   ├─────────────┤   ├─────────────┤
        │ Row 0       │   │ Row 0       │   │ Rows 0-1    │
        │ Client List │   │ Filter bar  │   │ Productivity│
        │ button      │   │             │   │ + Today's   │
        ├─────────────┤   ├─────────────┤   │ Work        │
        │ Rows 1-2    │   │ Row 1       │   ├─────────────┤
        │ Note entry  │   │ Notes       │   │ Row 2       │
        │ form        │   │ DataGrid    │   │ Upcoming    │
        │             │   ├─────────────┤   │ Tasks       │
        │             │   │ Row 2       │   │             │
        │             │   │ Forms       │   │             │
        │             │   │ checklist   │   │             │
        └─────────────┴───┴─────────────┴───┴─────────────┘
    -->
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ COL 0 ROW 0: CLIENT LIST BUTTON ═══ -->
        <Grid Grid.Column="0"
              Grid.Row="0"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource SmallButton}"
                    ToolTip="Settings"
                    Width="28"
                    Command="{Binding OpenSettingsWindowCommand}"
                    Background="Transparent"
                    Padding="0">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE713;"
                           FontSize="14"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
            </Button>
            <Button Command="{Binding OpenNotesWindowCommand}"
                    Grid.Column="4"
                    Width="32"
                    Height="32"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="Notes">
                <TextBlock Text="&#xE8F1;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           Foreground="#9C7A5C" />
            </Button>
            <Button x:Name="SchedulerButton"
                    Grid.Column="2"
                    Style="{StaticResource SmallButton}"
                    ToolTip="Scheduler"
                    Width="28"
                    Command="{Binding OpenSchedulerCommand}"
                    Background="Transparent"
                    Padding="0">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE787;"
                           FontSize="14"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
            </Button>

            <Button Grid.Column="6"
                    Content="Client List"
                    Style="{StaticResource SmallButton}"
                    Command="{Binding OpenClientListCommand}"
                    HorizontalAlignment="Stretch" />
        </Grid>

        <Popup x:Name="SchedulerPopup"
               PlacementTarget="{Binding ElementName=SchedulerButton}"
               Placement="Bottom"
               IsOpen="{Binding DataContext.IsSchedulerOpen, 
    RelativeSource={RelativeSource AncestorType=Window}}"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Slide">

            <Border Background="White"
                    BorderBrush="#E8D0B8"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16" >

                <StackPanel Width="320">

                    <!-- Header with navigation -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="◀"
                                Style="{StaticResource SmallButton}"
                                Command="{Binding PreviousMonthCommand}"
                                Width="28" />

                        <TextBlock Grid.Column="1"
                                   Text="{Binding MonthLabel}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#3D2B1F"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <Button Grid.Column="2"
                                Content="▶"
                                Style="{StaticResource SmallButton}"
                                Command="{Binding NextMonthCommand}"
                                Width="28" />
                    </Grid>

                    <!-- Day header row -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Mon"
                                   Style="{StaticResource LabelStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="Tue"
                                   Style="{StaticResource LabelStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="Wed"
                                   Style="{StaticResource LabelStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="3"
                                   Text="Thu"
                                   Style="{StaticResource LabelStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="4"
                                   Text="Fri"
                                   Style="{StaticResource LabelStyle}"
                                   HorizontalAlignment="Center" />
                    </Grid>

                    <!-- Tile grid -->
                    <ItemsControl ItemsSource="{Binding Tiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="2"
                                        Command="{Binding DataContext.ToggleTileCommand, 
                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding IsInteractable}"
                                        Background="{Binding IsExcluded, Converter={StaticResource BoolToTileColorConverter}}"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Height="44">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                <Grid>
                                                    <TextBlock Text="{Binding Letter}"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="#3D2B1F"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Date, StringFormat={}{0:d}}"
                                                               FontSize="8"
                                                               Foreground="#9C7A5C"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"
                                                               Margin="0,0,3,2" />
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Days scheduled footer -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="DAYS SCHEDULED"
                                   Style="{StaticResource LabelStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DaysScheduled}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#3D2B1F" />
                    </Grid>

                </StackPanel>
            </Border>
        </Popup>

        <!-- ═══ COL 0 ROWS 1-2: NOTE ENTRY FORM ═══ -->
        <Border Grid.Column="0"
                Grid.Row="1"
                Grid.RowSpan="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="NEW NOTE"
                           Grid.Row="0"
                           Style="{StaticResource SectionHeader}" />

                <TextBlock Text="CLIENT"
                           Grid.Row="1"
                           Style="{StaticResource LabelStyle}" />
                <ComboBox Grid.Row="2"
                          ItemsSource="{Binding People}"
                          SelectedItem="{Binding SelectedPerson}"
                          DisplayMemberPath="FullName" />

                <TextBlock Text="STATUS"
                           Grid.Row="3"
                           Style="{StaticResource LabelStyle}" />
                <ComboBox Grid.Row="4"
                          ItemsSource="{Binding NoteStatusOptions}"
                          SelectedItem="{Binding Status, Mode=TwoWay}" />


                <Grid Margin="0,0,0,10" Grid.Row="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="NOTE TYPE"
                               Style="{StaticResource LabelStyle}" 
                               Grid.Row="0"
                               Grid.ColumnSpan="2" />
                    <RadioButton Grid.Row="1"
                                 Grid.Column="1"
                                 Content="Visit"
                                 Margin="0,0,12,4"
                                 Foreground="#3D2B1F"
                                 GroupName="NoteType"
                                 IsChecked="{Binding SelectedNoteType, 
      Converter={StaticResource EnumToBoolConverter}, 
      ConverterParameter=Visit}" />

                    <RadioButton Grid.Row="1"
                                 Grid.Column="3"
                                 Content="Contact"
                                 Margin="0,0,12,4"
                                 Foreground="#3D2B1F"
                                 GroupName="NoteType"
                                 IsChecked="{Binding SelectedNoteType, 
      Converter={StaticResource EnumToBoolConverter}, 
      ConverterParameter=Contact}" />

                    <RadioButton Grid.Row="2"
                                 Grid.Column="1"
                                 Content="Other"
                                 Margin="0,0,12,4"
                                 Foreground="#3D2B1F"
                                 GroupName="NoteType"
                                 IsChecked="{Binding SelectedNoteType, 
      Converter={StaticResource EnumToBoolConverter}, 
      ConverterParameter=Other}" />

                    <RadioButton Grid.Row="2"
                                 Grid.Column="3"
                                 Content="Form"
                                 Margin="0,0,8,4"
                                 Foreground="#3D2B1F"
                                 GroupName="NoteType"
                                 IsChecked="{Binding SelectedNoteType, 
      Converter={StaticResource EnumToBoolConverter}, 
      ConverterParameter=Form}" />

                    <ComboBox Grid.Row="3"
                              Grid.ColumnSpan="4"
                              ItemsSource="{Binding FormTypes}"
                              SelectedItem="{Binding SelectedFormType, Mode=TwoWay}"
                              Visibility="{Binding IsFormNote, 
   Converter={StaticResource BoolToVisibilityConverter}}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <!-- Units, Date, Narrative -->
                <Grid Grid.Row="7">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="UNITS"
                               Grid.Row="0"
                               Style="{StaticResource LabelStyle}" />
                    <TextBox Grid.Row="1"
                             Text="{Binding Units}" />

                    <TextBlock Text="DATE"
                               Grid.Row="2"
                               Style="{StaticResource LabelStyle}" />
                    <DatePicker Grid.Row="3"
                                SelectedDate="{Binding EventDate}" />

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="NARRATIVE"
                                   Style="{StaticResource LabelStyle}" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal">
                            <Button Command="{Binding DecreaseNarrativeFontCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="4,0">
                                <TextBlock Text="A"
                                           FontSize="11"
                                           Foreground="#9C7A5C" />
                            </Button>
                            <Button Command="{Binding IncreaseNarrativeFontCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="4,0">
                                <TextBlock Text="A"
                                           FontSize="16"
                                           Foreground="#9C7A5C"
                                           FontWeight="SemiBold" />
                            </Button>
                        </StackPanel>
                    </Grid>
                    <TextBox Grid.Row="5"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             SpellCheck.IsEnabled="True"
                             FontFamily="{StaticResource NarrativeFont}"
                             FontSize="{Binding NarrativeFontSize}"
                             Text="{Binding Narrative}" />
                </Grid>

                <Button Grid.Row="8"
                        Content="Submit Note"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SubmitNoteCommand}"
                        Margin="0,10,0,0" />
            </Grid>
        </Border>

        <!-- ═══ COL 2 ROW 0: FILTER BAR ═══ -->
        <Grid Grid.Row="0"
              Grid.Column="2"
              Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="160" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="FILTER NOTES"
                       Style="{StaticResource LabelStyle}" />
            <TextBlock Grid.Row="0"
                       Grid.Column="2"
                       Text="FILTER STATUS"
                       Style="{StaticResource LabelStyle}" />

            <TextBox x:Name="SearchTextBox"
                     Grid.Row="1"
                     Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Grid.Row="1"
                      Grid.Column="2"
                      Height="{Binding ActualHeight, ElementName=SearchTextBox}"
                      ItemsSource="{Binding NoteStatusOptions}"
                      SelectedItem="{Binding FilterStatus}" />
        </Grid>

        <!-- ═══ COL 2 ROW 1: NOTES DATAGRID ═══ -->
        <Border Grid.Column="2"
                Grid.Row="1"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Margin="0,0,0,12">
            <DataGrid ItemsSource="{Binding NotesView}"
                      SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                      MouseDoubleClick="DataGrid_MouseDoubleClick"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="White"
                      AlternatingRowBackground="#FDF6EC"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F0E0D0"
                      HeadersVisibility="Column"
                      Margin="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding EventDate, StringFormat={}{0:MM/dd}}"
                                        Width="60" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="90" />
                    <DataGridTextColumn Header="Units"
                                        Binding="{Binding Units}"
                                        Width="50" />
                    <DataGridTextColumn Header="Type"
                   Binding="{Binding NoteType}"
                   Width="80" />
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Delete Note"
                                  Command="{Binding DeleteNoteCommand}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Border>

        <!-- ═══ COL 2 ROW 2: FORMS CHECKLIST ═══ -->
        <!-- ═══ COL 2 ROW 2: FORMS CHECKLIST + MONTHLY PRODUCTIVITY ═══ -->
        <Border Grid.Column="2"
                Grid.Row="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,12">
            <StackPanel>

                <!-- Forms Checklist -->
                <Border Grid.Column="2"
                        Grid.Row="2"
                        Background="White"
                        BorderBrush="#E8D0B8"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="90-Day Reviews"
                                   Style="{StaticResource SectionHeader}" />
                        <CheckBox Grid.Row="1"
                                  Grid.Column="0"
                                  Content="Quarter 1"
                                  Foreground="#3D2B1F"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding Q1RCompliant, Mode=OneWay}"
                                  Command="{Binding ToggleFormCommand}"
                                  CommandParameter="{x:Static local:FormType.Q1R}" />
                        <CheckBox Grid.Row="2"
                                  Grid.Column="0"
                                  Content="Quarter 2"
                                  Foreground="#3D2B1F"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding Q2RCompliant, Mode=OneWay}"
                                  Command="{Binding ToggleFormCommand}"
                                  CommandParameter="{x:Static local:FormType.Q2R}" />
                        <CheckBox Grid.Row="3"
                                  Grid.Column="0"
                                  Content="Quarter 3"
                                  Foreground="#3D2B1F"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding Q3RCompliant, Mode=OneWay}"
                                  Command="{Binding ToggleFormCommand}"
                                  CommandParameter="{x:Static local:FormType.Q3R}" />
                        <CheckBox Grid.Row="4"
                                  Grid.Column="0"
                                  Content="Quarter 4"
                                  Foreground="#3D2B1F"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding Q4RCompliant, Mode=OneWay}"
                                  Command="{Binding ToggleFormCommand}"
                                  CommandParameter="{x:Static local:FormType.Q4R}" />

                        <TextBlock Grid.Row="0"
                                   Grid.Column="2"
                                   Text="Annual Forms"
                                   Style="{StaticResource SectionHeader}" />
                        <CheckBox Grid.Row="1"
                                  Grid.Column="2"
                                  Content="PCP"
                                  Foreground="#3D2B1F"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding PcpCompliant, Mode=OneWay}"
                                  Command="{Binding ToggleFormCommand}"
                                  CommandParameter="{x:Static local:FormType.PCP}" />
                        <CheckBox Grid.Row="2"
                                  Grid.Column="2"
                                  Content="Comp Assessment"
                                  Foreground="#3D2B1F"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding CompAssessmentCompliant, Mode=OneWay}"
                                  Command="{Binding ToggleFormCommand}"
                                  CommandParameter="{x:Static local:FormType.ComprehensiveAssessment}" />
                        <CheckBox Grid.Row="3"
                                  Grid.Column="2"
                                  Content="Reclassification"
                                  Foreground="#3D2B1F"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding ReclassificationCompliant, Mode=OneWay}"
                                  Command="{Binding ToggleFormCommand}"
                                  CommandParameter="{x:Static local:FormType.Reclassification}" />
                        <CheckBox Grid.Row="4"
                                  Grid.Column="2"
                                  Content="Safety Plan"
                                  Foreground="#3D2B1F"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding SafetyPlanCompliant, Mode=OneWay}"
                                  Command="{Binding ToggleFormCommand}"
                                  CommandParameter="{x:Static local:FormType.SafetyPlan}" />
                        <CheckBox Grid.Row="5"
                                  Grid.Column="2"
                                  Content="Privacy Practices"
                                  Foreground="#3D2B1F"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding PrivacyPracticesCompliant, Mode=OneWay}"
                                  Command="{Binding ToggleFormCommand}"
                                  CommandParameter="{x:Static local:FormType.PrivacyPractices}" />

                        <TextBlock Grid.Row="0"
                                   Grid.Column="4"
                                   Text="Releases"
                                   Style="{StaticResource SectionHeader}" />
                        <CheckBox Grid.Row="1"
                                  Grid.Column="4"
                                  Content="DHHS"
                                  Foreground="#3D2B1F"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding ReleaseDhhsCompliant, Mode=OneWay}"
                                  Command="{Binding ToggleFormCommand}"
                                  CommandParameter="{x:Static local:FormType.Release_DHHS}" />
                        <CheckBox Grid.Row="2"
                                  Grid.Column="4"
                                  Content="Agency"
                                  Foreground="#3D2B1F"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding ReleaseAgencyCompliant, Mode=OneWay}"
                                  Command="{Binding ToggleFormCommand}"
                                  CommandParameter="{x:Static local:FormType.Release_Agency}" />
                        <CheckBox Grid.Row="3"
                                  Grid.Column="4"
                                  Content="Medical"
                                  Foreground="#3D2B1F"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding ReleaseMedicalCompliant, Mode=OneWay}"
                                  Command="{Binding ToggleFormCommand}"
                                  CommandParameter="{x:Static local:FormType.Release_Medical}" />
                    </Grid>
                </Border>
                <Separator Margin="0,12,0,12" />

                <!-- Monthly Productivity -->
                <TextBlock Text="MONTHLY PRODUCTIVITY"
                           Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PENDING"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding PendingUnits}"
                                   FontSize="20"
                                   Foreground="#3D2B1F" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="LOGGED"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding LoggedUnits}"
                                   FontSize="20"
                                   Foreground="#3D2B1F" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ABANDONED"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding AbandonedUnits}"
                                   FontSize="20"
                                   Foreground="#3D2B1F" />
                    </StackPanel>
                </Grid>

                <!-- Progress toward threshold -->
                <TextBlock Style="{StaticResource LabelStyle}">
    <Run Text="{Binding LoggedUnits, Mode=OneWay}" />
    <Run Text=" / " />
    <Run Text="{Binding Threshold, Mode=OneWay}" />
    <Run Text=" units" />
                </TextBlock>
                <ProgressBar Minimum="0"
                             Maximum="{Binding SafeThreshold, TargetNullValue=1, FallbackValue=1}"                             
                             Value="{Binding LoggedUnits, Mode=OneWay}"
                             Height="10"
                             Margin="0,4,0,8"
                             Foreground="#C87941"
                             Background="#E8D0B8"
                             BorderThickness="0" />

                <!-- Estimated incentive -->
                <TextBlock Text="ESTIMATED INCENTIVE"
                           Style="{StaticResource LabelStyle}" />
                <TextBlock Text="{Binding EstimatedIncentive, StringFormat=C}"
                           FontSize="20"
                           Foreground="#3D2B1F" />

            </StackPanel>
        </Border>
        <!-- ═══ COL 4 ROWS 0-1: TODAY'S WORK (tall) ═══ -->
        <Border Grid.Column="4"
                Grid.Row="0"
                Grid.RowSpan="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <TextBlock Text="TODAY'S WORK"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#3D2B1F"
                               VerticalAlignment="Center" />
                    <Button Command="{Binding OpenScratchpadHistoryCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="8,0,0,0"
                            Padding="4"
                            ToolTip="Browse scratchpad history">
                        <TextBlock Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="#9C7A5C" />
                    </Button>
                </StackPanel>
                <TextBox x:Name="TodaysWorkBox"
                         Grid.Row="1"
                         FontFamily="{StaticResource NarrativeFont}"
                         FontSize="{Binding NarrativeFontSize}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         SpellCheck.IsEnabled="True"
                         VerticalScrollBarVisibility="Auto"
                         VerticalAlignment="Stretch"
                         Text="{Binding ScratchpadContent, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="0"
                         KeyDown="TodaysWorkBox_KeyDown" />
            </Grid>
        </Border>

        <!-- ═══ COL 4 ROW 2: UPCOMING TASKS ═══ -->
        <Border Grid.Column="4"
                Grid.Row="2"
                Background="White"
                BorderBrush="#E8D0B8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,4">
                    <TextBlock Text="UPCOMING TASKS"
                               Style="{StaticResource SectionHeader}"
                               Margin="0,0,12,0" />
                    <RadioButton GroupName="SortEventsBy"
                                 Content="By Date"
                                 IsChecked="{Binding SortByDate, Mode=TwoWay}"
                                 Foreground="#9C7A5C"
                                 FontSize="11"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center" />
                    <RadioButton GroupName="SortEventsBy"
                                 Content="By Type"
                                 IsChecked="{Binding SortByDate, 
                             Converter={StaticResource InverseBoolConverter}, 
                             Mode=TwoWay}"
                                 Foreground="#9C7A5C"
                                 FontSize="11"
                                 VerticalAlignment="Center" />
                </StackPanel>

                <Separator Grid.Row="1" />

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="FORMS"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,6" />
                        <ItemsControl ItemsSource="{Binding FormEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,3">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#3D2B1F"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Date, StringFormat={}{0:MMM d}}"
                                                   FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground"
                                                            Value="#9C7A5C" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Kind}"
                                                                     Value="{x:Static local:UpcomingEventKind.LateReview}">
                                                            <Setter Property="Foreground"
                                                                    Value="#C0392B" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="VISITS"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,6" />
                        <ItemsControl ItemsSource="{Binding VisitEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,3">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#3D2B1F"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Date, StringFormat={}{0:MMM d}}"
                                                   Foreground="#9C7A5C"
                                                   FontSize="11" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="CONTACTS"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,6" />
                        <ItemsControl ItemsSource="{Binding ContactEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,3">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#3D2B1F"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Date, StringFormat={}{0:MMM d}}"
                                                   Foreground="#9C7A5C"
                                                   FontSize="11" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>