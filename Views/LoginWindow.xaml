<Window x:Class="Proofer.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proofer.Views"
        mc:Ignorable="d"
        Title="Log In"
        Height="150"
        Width="300">
    <Grid Margin="12,12,12,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Select User"
                   Grid.Row="0"
                   Grid.Column="0"
                   Margin="0,0,0,4" />
        <ComboBox Grid.Row="0"
                  Grid.Column="3"
                  Margin="0,0,0,4" 
                  ItemsSource="{Binding Users, Mode=OneWay}"
                  DisplayMemberPath="DisplayName"  />
        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Text="Password" />
        <PasswordBox Grid.Row="1"
                 Grid.Column="3" Margin="0,0,0,4"/>
        <Button Content="Enter"
                Grid.Row="2"
                Grid.Column="3"
                Margin="2,0,2,0"
                Command="{Binding LoginCommand}"/>
        <TextBlock Grid.Row="3"
                   Grid.Column="3"
                   Text="Create New User"
                   FontSize="8"
                   Foreground="Blue"
                   Cursor="Hand"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0">
            <TextBlock.InputBindings>
                <MouseBinding Gesture="LeftClick"
                              Command="{Binding OpenNewUserWindowCommand}" />
            </TextBlock.InputBindings>
        </TextBlock>

    </Grid>
</Window>
