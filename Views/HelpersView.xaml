<UserControl x:Class="Sati.Views.HelpersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FDF6EC"
             TextElement.FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ================================================================ -->
        <!-- SIDEBAR                                                           -->
        <!-- ================================================================ -->
        <Border Grid.Column="0"
                Background="#F5EAD8"
                BorderBrush="#E8D0B8"
                BorderThickness="0,0,1,0">
            <StackPanel>

                <TextBlock Text="HELPERS"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#9C7A5C"
                           Margin="12,14,12,10" />

                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,8">

                                <!-- Group header -->
                                <TextBlock Text="{Binding GroupTitle}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#C87941"
                                           Margin="12,6,12,4" />

                                <!-- Items -->
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Cursor="Hand"
                                                    Padding="0">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.SelectItemCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  CommandParameter="{Binding}" />
                                                </Border.InputBindings>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background"
                                                                Value="Transparent" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver"
                                                                     Value="True">
                                                                <Setter Property="Background"
                                                                        Value="#EDD9C0" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12"
                                                           Foreground="#3D2B1F"
                                                           Margin="20,5,12,5"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>

        <!-- ================================================================ -->
        <!-- MAIN CONTENT                                                      -->
        <!-- ================================================================ -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24,20">
            <StackPanel>

                <TextBlock Text="{Binding ContentTitle}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#3D2B1F"
                           Margin="0,0,0,16"
                           TextWrapping="Wrap" />

                <TextBlock Text="{Binding ContentBody}"
                           FontSize="13"
                           Foreground="#3D2B1F"
                           TextWrapping="Wrap"
                           LineHeight="24"
                           Visibility="{Binding HasSelection,
                               Converter={StaticResource BoolToVisibilityConverter}}" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>