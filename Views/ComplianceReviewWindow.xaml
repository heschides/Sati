<Window x:Class="Sati.Views.ComplianceReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Sati.Converters"
        Title="Review Form Compliance"
        Width="420"
        SizeToContent="Height"
        MaxHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FDF6EC">

    <Window.Resources>
        <converters:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />

        <Style x:Key="LabelStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="#9C7A5C" />
        </Style>

        <Style x:Key="PrimaryButton"
               TargetType="Button">
            <Setter Property="Height"
                    Value="36" />
            <Setter Property="Background"
                    Value="#C87941" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#A85E28" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="24">
        <StackPanel>
            <TextBlock Text="Review Form Compliance"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#3D2B1F"
                       Margin="0,0,0,8" />

            <TextBlock TextWrapping="Wrap"
                       Foreground="#9C7A5C"
                       FontSize="13"
                       Margin="0,0,0,16">
                <Run Text="Based on " />
                <Run Text="{Binding ClientName}"
                     FontWeight="SemiBold"
                     Foreground="#3D2B1F" />
                <Run Text="'s effective date, the following forms are assumed compliant. Uncheck any that are not current." />
            </TextBlock>

            <Border Background="White"
                    BorderBrush="#E8D0B8"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,0,16">
                <ScrollViewer MaxHeight="380"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Forms}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsCompliant, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0" />

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Type, Converter={StaticResource EnumDescriptionConverter}}"
                                               Foreground="#3D2B1F"
                                               FontSize="13"
                                               VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DueDate, StringFormat={}{0:MMM d, yyyy}}"
                                               Foreground="#9C7A5C"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Button Content="Confirm"
                    Style="{StaticResource PrimaryButton}"
                    Click="Confirm_Click" />
        </StackPanel>
    </Border>
</Window>
