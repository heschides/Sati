<UserControl x:Class="Sati.Views.GuidanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FDF6EC"
             TextElement.FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ================================================================ -->
        <!-- SIDEBAR                                                           -->
        <!-- ================================================================ -->
        <Border Grid.Column="0"
                Background="#F5EAD8"
                BorderBrush="#E8D0B8"
                BorderThickness="0,0,1,0">
            <StackPanel>

                <TextBlock Text="GUIDANCE"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#9C7A5C"
                           Margin="12,14,12,10" />

                <!-- Search -->
                <Border Margin="12,0,12,6"
                        Background="White"
                        BorderBrush="#D4A882"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="6,4"
                             FontSize="12"
                             Foreground="#3D2B1F"
                             Margin="0" />
                </Border>

                <!-- Collapse All -->
                <Button Margin="12,0,12,12"
                        Height="28"
                        Style="{StaticResource SmallButton}"
                        Command="{Binding CollapseAllCommand}">
                    <TextBlock Text="Collapse all"
                               FontSize="11"
                               Foreground="#3D2B1F" />
                </Button>

                <!-- Quick nav -->
                <TextBlock Text="TOPICS"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#9C7A5C"
                           Margin="12,0,12,6" />

                <ItemsControl ItemsSource="{Binding Blocks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}"
                                       FontSize="11"
                                       Foreground="#9C7A5C"
                                       Margin="12,2"
                                       Cursor="Hand"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding IsVisible,
                                           Converter={StaticResource BoolToVisibilityConverter}}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>

        <!-- ================================================================ -->
        <!-- MAIN CONTENT — scrollable accordion                              -->
        <!-- ================================================================ -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="20,16">
            <ItemsControl ItemsSource="{Binding Blocks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8"
                                Background="White"
                                BorderBrush="#E8D0B8"
                                BorderThickness="1"
                                CornerRadius="6"
                                Visibility="{Binding IsVisible,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>

                                <!-- Accordion header -->
                                <Border Padding="14,10"
                                        Cursor="Hand"
                                        Background="Transparent">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding ToggleCommand}" />
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="10"
                                                       Foreground="#9C7A5C"
                                                       Margin="0,0,0,2" />
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="#3D2B1F"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"
                                                   Foreground="#9C7A5C">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"
                                                            Value="&#xE970;" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpanded}"
                                                                     Value="True">
                                                            <Setter Property="Text"
                                                                    Value="&#xE971;" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- Accordion body — only visible when expanded -->
                                <Border Padding="14,0,14,14"
                                        Visibility="{Binding IsExpanded,
                                            Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Content}"
                                               FontSize="13"
                                               Foreground="#3D2B1F"
                                               TextWrapping="Wrap"
                                               LineHeight="22" />
                                </Border>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>