<UserControl x:Class="Sati.Views.TeamOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             Background="#FDF6EC">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,32">

            <!-- ── Summary cards ── -->
            <UniformGrid Columns="4"
                         Margin="0,0,0,24">
                <Border Margin="0,0,6,0"
                        Background="White"
                        BorderBrush="#EDD9C0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalClients}"
                                   FontFamily="Inter"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="#3D2B1F" />
                        <TextBlock Text="Total Clients"
                                   FontFamily="Inter"
                                   FontSize="11"
                                   Foreground="#8A7A6A"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Border Margin="6,0"
                        Background="White"
                        BorderBrush="#EDD9C0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalOverdue}"
                                   FontFamily="Inter"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="#A6607A" />
                        <TextBlock Text="Overdue Items"
                                   FontFamily="Inter"
                                   FontSize="11"
                                   Foreground="#8A7A6A"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Border Margin="6,0"
                        Background="White"
                        BorderBrush="#EDD9C0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalNotesThisMonth}"
                                   FontFamily="Inter"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="#3D2B1F" />
                        <TextBlock Text="Notes This Month"
                                   FontFamily="Inter"
                                   FontSize="11"
                                   Foreground="#8A7A6A"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Border Margin="6,0,0,0"
                        Background="White"
                        BorderBrush="#EDD9C0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="{Binding AvgComplianceLabel}"
                                   FontFamily="Inter"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="#5A8A5A" />
                        <TextBlock Text="Avg Compliance"
                                   FontFamily="Inter"
                                   FontSize="11"
                                   Foreground="#8A7A6A"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Case manager table ── -->
            <TextBlock Text="CASE MANAGERS"
                       FontFamily="Inter"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#8A7A6A"
                       Margin="0,0,0,8" />
            <DataGrid ItemsSource="{Binding CaseManagers}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionUnit="FullRow"
                      SelectionMode="Single"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#FAF0E4"
                      HorizontalGridLinesBrush="#EDD9C0"
                      Margin="0,0,0,28">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"
                                Value="Transparent" />
                        <Setter Property="Foreground"
                                Value="#8A7A6A" />
                        <Setter Property="FontFamily"
                                Value="Inter" />
                        <Setter Property="FontSize"
                                Value="11" />
                        <Setter Property="FontWeight"
                                Value="SemiBold" />
                        <Setter Property="Padding"
                                Value="8,8" />
                        <Setter Property="BorderThickness"
                                Value="0,0,0,1" />
                        <Setter Property="BorderBrush"
                                Value="#EDD9C0" />
                        <Setter Property="SeparatorVisibility"
                                Value="Collapsed" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness"
                                Value="0" />
                        <Setter Property="Padding"
                                Value="8,6" />
                        <Setter Property="Foreground"
                                Value="#3D2B1F" />
                        <Setter Property="FontFamily"
                                Value="Inter" />
                        <Setter Property="Background"
                                Value="Transparent" />
                        <Setter Property="FocusVisualStyle"
                                Value="{x:Null}" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#EDD9C0" />
                                <Setter Property="Foreground"
                                        Value="#3D2B1F" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="BorderThickness"
                                Value="0" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#EDD9C0" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding DisplayName}"
                                        Width="*" />
                    <DataGridTextColumn Header="Clients"
                                        Binding="{Binding ClientCount}"
                                        Width="70" />
                    <DataGridTextColumn Header="Overdue"
                                        Binding="{Binding OverdueCount}"
                                        Width="70" />
                    <DataGridTextColumn Header="Notes"
                                        Binding="{Binding NotesThisMonth}"
                                        Width="70" />
                    <DataGridTemplateColumn Header="Progress"
                                            Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                             Maximum="100"
                                             Height="8"
                                             Margin="8,6"
                                             BorderThickness="0">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar">
                                            <Setter Property="Foreground"
                                                    Value="#C87941" />
                                            <Setter Property="Background"
                                                    Value="#EDD9C0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusLevel}"
                                                             Value="Ok">
                                                    <Setter Property="Foreground"
                                                            Value="#5A8A5A" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusLevel}"
                                                             Value="Danger">
                                                    <Setter Property="Foreground"
                                                            Value="#A6607A" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Status"
                                            Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3"
                                        Padding="6,2"
                                        HorizontalAlignment="Left"
                                        Margin="6,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="#EDD9C0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusLevel}"
                                                             Value="Ok">
                                                    <Setter Property="Background"
                                                            Value="#D4EDD4" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusLevel}"
                                                             Value="Danger">
                                                    <Setter Property="Background"
                                                            Value="#EDD4D4" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusLabel}"
                                               FontFamily="Inter"
                                               FontSize="11"
                                               Foreground="#3D2B1F" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── Compliance chart ── -->
            <TextBlock Text="COMPLIANCE BY CASE MANAGER"
                       FontFamily="Inter"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#8A7A6A"
                       Margin="0,0,0,8" />
            <Border Background="White"
                    BorderBrush="#EDD9C0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <oxy:PlotView Name="ComplianceChart"
                    Model="{Binding ComplianceChartModel}"
                              Height="300"
                              Background="Transparent" />
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>